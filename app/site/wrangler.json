{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "agents-txt-site-production",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-01-28",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"run_worker_first": true
	},
	"routes": [
		{ "pattern": "agents-txt.com", "custom_domain": true }
	],
	"kv_namespaces": [
		{ "binding": "SESSION", "id": "c782398569a84842aafe66164d5366b8" }
	],
	"services": [
		{
			"binding": "MCP",
			"service": "agents-txt-mcp-production"
		},
		{
			"binding": "AUTH",
			"service": "agents-txt-auth-production"
		}
	],
	"ratelimits": [
		{
			"name": "RL_DEMO",
			"namespace_id": "3001",
			"simple": { "limit": 30, "period": 60 }
		}
	],
	"env": {
		"production": {
			"name": "agents-txt-site-production",
			"routes": [
				{ "pattern": "agents-txt.com", "custom_domain": true }
			],
			"kv_namespaces": [
				{ "binding": "SESSION", "id": "c782398569a84842aafe66164d5366b8" }
			],
			"services": [
				{
					"binding": "MCP",
					"service": "agents-txt-mcp-production"
				},
				{
					"binding": "AUTH",
					"service": "agents-txt-auth-production"
				}
			],
			"ratelimits": [
				{
					"name": "RL_DEMO",
					"namespace_id": "3001",
					"simple": { "limit": 30, "period": 60 }
				}
			]
		}
	}
}