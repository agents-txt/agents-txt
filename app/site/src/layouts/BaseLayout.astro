---
interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  /** Set true on a page that has FAQ-style Q&A content so the FAQPage JSON-LD block is emitted. Off by default — most pages do not have FAQ markup. */
  isFaq?: boolean;
}

const {
  title = 'agents.txt Standard',
  description = 'A lightweight, protocol-agnostic capability declaration format for AI agent interactions. Layer 4 of the agent-readiness stack.',
  canonicalUrl = 'https://agents-txt.com',
  isFaq = false,
} = Astro.props;

// Pages that get the FAQPage block. The /about page reads as Q&A in shape;
// surfacing it as FAQPage gives schema-breadth signal to AEO scanners.
const faqGraph = isFaq
  ? [{
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: [
        {
          '@type': 'Question',
          name: 'What is agents.txt?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'agents.txt is an open specification for AI agent capability declarations. A site publishes a plain-text /agents.txt file plus a structured /agents.json companion describing the payment rails, authorization protocols, MCP servers, agent skills, A2A AgentCards, UCP profiles, and WebMCP pages an agent can use.',
          },
        },
        {
          '@type': 'Question',
          name: 'Who maintains the specification?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The agents.txt working group on GitHub at github.com/agents-txt. The specification and reference deployment are open-source. The spec is CC0 (public domain); the reference code is Apache 2.0.',
          },
        },
        {
          '@type': 'Question',
          name: 'How is agents.txt different from MCP, A2A, or llms.txt?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'agents.txt is Layer 4 of the agent-readiness stack: a capability declaration. It points agents at the MCP servers, A2A AgentCards, payment protocols (x402, MPP, AP2), and authorization protocols (agent-auth, oauth2, auth-md) a site supports. Those protocols are independent specifications; agents.txt is the discovery file that announces them.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is there a CLI or SDK?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes, herald (@agentstxtdev/herald on npm). It generates the agents.txt, agents.json, llms.txt, robots.txt, sitemap.xml, security.txt, and the four ecosystem discovery files from a single config. herald is a separate project; the spec itself can be hand-written or generated by any tool.',
          },
        },
        {
          '@type': 'Question',
          name: 'How do I adopt agents.txt on my site?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Three paths: hand-write the two files following the spec at agents-txt.com/spec, use herald to generate them from a config, or write your own generator against the published JSON Schema. Validate with the live audit tool at agents-txt.com/audit.',
          },
        },
      ],
    }]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="agents.txt" />
    <meta property="og:image" content="https://agents-txt.com/icon-512.png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@hsologarcia" />
    <meta name="twitter:creator" content="@hsologarcia" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://agents-txt.com/icon-512.png" />

    <link rel="icon" type="image/svg+xml" href="/tab-icon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data: identity, software type, and entity links for agents
         and search engines. Three @graph nodes share the same canonical URLs
         so a parser walking either node can resolve back to the same site. -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'WebSite',
            '@id': 'https://agents-txt.com/#website',
            name: 'agents.txt',
            alternateName: 'agents.txt Standard',
            url: 'https://agents-txt.com',
            description:
              'The open specification for AI agent capability declarations. Layer 4 of the agent-readiness stack.',
            publisher: { '@id': 'https://agents-txt.com/#organization' },
            inLanguage: 'en',
            // Speakable markup tells voice-first agents which CSS selectors
            // carry the canonical summary content to read aloud or surface
            // when the page is opened via an assistant.
            speakable: {
              '@type': 'SpeakableSpecification',
              cssSelector: ['h1', 'h2', '.prose p', 'dl dd'],
            },
          },
          {
            '@type': 'Organization',
            '@id': 'https://agents-txt.com/#organization',
            name: 'agents.txt',
            url: 'https://agents-txt.com',
            logo: {
              '@type': 'ImageObject',
              url: 'https://agents-txt.com/icon-512.png',
              width: 512,
              height: 512,
            },
            description:
              'Working group maintaining the agents.txt open specification for AI agent capability declarations.',
            sameAs: [
              'https://github.com/agents-txt',
              'https://github.com/agents-txt/agents-txt',
              'https://www.npmjs.com/org/agentstxtdev',
              'https://twitter.com/hsologarcia',
            ],
            contactPoint: [
              {
                '@type': 'ContactPoint',
                contactType: 'security',
                email: 'security@agents-txt.com',
                url: 'https://agents-txt.com/.well-known/security.txt',
                availableLanguage: ['English'],
              },
              {
                '@type': 'ContactPoint',
                contactType: 'technical support',
                url: 'https://github.com/agents-txt/agents-txt/issues',
                availableLanguage: ['English'],
              },
            ],
          },
          {
            '@type': ['SoftwareApplication', 'TechArticle'],
            '@id': 'https://agents-txt.com/#spec',
            name: 'agents.txt Standard',
            alternateName: ['agents.txt', 'agents-txt'],
            url: 'https://agents-txt.com/spec',
            applicationCategory: 'DeveloperApplication',
            operatingSystem: 'Any',
            description:
              'Plain-text capability declaration format that lets AI agents discover a website’s payment rails (x402, MPP, AP2), authorization protocols (agent-auth, oauth2, auth-md), MCP endpoints, Skills, A2A AgentCards, UCP profiles, and WebMCP pages from a single /agents.txt file plus its structured /agents.json companion.',
            license: 'https://creativecommons.org/publicdomain/zero/1.0/',
            softwareVersion: '1.0',
            offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            author: { '@id': 'https://agents-txt.com/#organization' },
            publisher: { '@id': 'https://agents-txt.com/#organization' },
            codeRepository: 'https://github.com/agents-txt/agents-txt',
            sameAs: [
              'https://github.com/agents-txt/agents-txt',
              'https://www.npmjs.com/package/@agentstxtdev/herald',
            ],
            keywords:
              'agents.txt, agent-readiness, MCP, x402, MPP, AP2, agent-auth, oauth2, auth-md, A2A, UCP, WebMCP, llms.txt, agentic web',
          },
          ...faqGraph,
        ],
      })}
    />
  </head>
  <body class="bg-white text-[#111] antialiased">
    <slot />

    <!--
      WebMCP registration (webmachinelearning.github.io/webmcp). Browsers that
      expose `navigator.modelContext` see this site advertising three read-only
      tools an in-page agent can call without leaving the document. Feature-
      detected so this is a no-op on browsers without the API and on SSR.
      Same surface the site already exposes via /mcp, restricted to the GETs
      that make sense from the page context.
    -->
    <script is:inline>
      (function () {
        if (typeof navigator === 'undefined') return;
        var ctx = navigator.modelContext;
        if (!ctx || typeof ctx.registerTool !== 'function') return;

        ctx.registerTool({
          name: 'fetch_agents_txt',
          description: "Fetch this site's /agents.txt — the plain-text capability declaration listing supported payment, auth, MCP, skills, A2A, and UCP discovery surfaces.",
          inputSchema: { type: 'object', properties: {}, additionalProperties: false },
          execute: async function () {
            var res = await fetch('/agents.txt', { headers: { Accept: 'text/plain' } });
            return await res.text();
          },
        });

        ctx.registerTool({
          name: 'fetch_agents_json',
          description: "Fetch this site's /agents.json — the structured JSON companion to agents.txt with full payment, auth, MCP, skills, A2A, and UCP block detail.",
          inputSchema: { type: 'object', properties: {}, additionalProperties: false },
          execute: async function () {
            var res = await fetch('/agents.json', { headers: { Accept: 'application/json' } });
            return await res.json();
          },
        });

        ctx.registerTool({
          name: 'fetch_api_catalog',
          description: "Fetch this site's /.well-known/api-catalog (RFC 9727 linkset+json) listing every machine-readable API surface declared by the site.",
          inputSchema: { type: 'object', properties: {}, additionalProperties: false },
          execute: async function () {
            var res = await fetch('/.well-known/api-catalog', { headers: { Accept: 'application/linkset+json, application/json' } });
            return await res.json();
          },
        });
      })();
    </script>
  </body>
</html>
