---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { SPEC_VERSION } from '../../config';
---

<BaseLayout
  title="Discovery & Content Layers Demo · agents.txt"
  description="Live demonstration of the discovery and content layers that sit beneath agents.txt: robots.txt (Layer 1), sitemap.xml (Layer 2), llms.txt + llms-full.txt (Layer 3), and the §4.5 serving headers cross-cut. Every file is fetched from this server in real time."
  canonicalUrl="https://agentstxt.dev/demo/llms"
>
  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-white border-b border-[#e5e5e5]">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="font-mono text-sm font-semibold tracking-tight text-[#111] no-underline whitespace-nowrap">
          agents.txt
        </a>
        <span class="text-[#ccc] select-none">/</span>
        <a href="/demo" class="text-sm text-[#555] hover:text-[#111] transition-colors no-underline whitespace-nowrap">Demos</a>
        <span class="text-[#ccc] select-none">/</span>
        <span class="text-sm text-[#111] whitespace-nowrap">Discovery</span>
      </div>
      <div class="flex items-center gap-x-3 sm:gap-x-5 shrink-0">
        <a href="/spec" class="text-xs text-[#555] hover:text-[#111] transition-colors no-underline">Spec</a>
        <a href="/agents.txt" class="font-mono text-xs text-[#555] hover:text-[#111] transition-colors no-underline">agents.txt</a>
        <a href="/agents.json" class="font-mono text-xs text-[#555] hover:text-[#111] transition-colors no-underline">agents.json</a>
        <a href="/demo" class="text-xs font-medium text-[#111] no-underline border-b border-[#111]">Demo</a>
        <span class="hidden sm:block text-[#ddd] select-none">|</span>
        <a href="https://github.com/agentstxtdev/agentstxt" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub"
          class="flex text-xs text-[#555] hover:text-[#111] transition-colors no-underline items-center gap-1">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      </div>
    </div>
  </header>

  <!-- Page body -->
  <div class="max-w-[1280px] mx-auto px-6 sm:px-10 pt-12 pb-24">
    <div class="max-w-[72ch]">

      <!-- Cover -->
      <div class="mb-10 pb-8 border-b border-[#e5e5e5]">
        <h1 class="text-2xl font-bold tracking-tight text-[#111] mb-1">
          Discovery & Content Layers: Live Demonstration
        </h1>
        <p class="text-sm text-[#777] font-mono mb-6">Layers 1, 2, 3 · robots.txt · sitemap.xml · llms.txt · §4.5 headers</p>
        <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-sm">
          <dt class="text-[#999] font-medium">Standards</dt>
          <dd class="text-[#111]">
            <a href="https://www.rfc-editor.org/rfc/rfc9309" target="_blank" rel="noopener noreferrer" class="font-mono underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all">RFC 9309</a>
            ·
            <a href="https://www.sitemaps.org/protocol.html" target="_blank" rel="noopener noreferrer" class="font-mono underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all">sitemaps.org 0.9</a>
            ·
            <a href="https://llmstxt.org" target="_blank" rel="noopener noreferrer" class="font-mono underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all">llmstxt.org</a>
            ·
            <a href="/spec#45-serving-requirements" class="font-mono underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all">agents.txt</a>
          </dd>
          <dt class="text-[#999] font-medium">Discovery</dt>
          <dd class="font-mono text-[#111]">/robots.txt · /sitemap.xml · /llms.txt · /llms-full.txt</dd>
          <dt class="text-[#999] font-medium">Transport</dt>
          <dd class="text-[#111]">HTTPS · Cloudflare CDN · static</dd>
          <dt class="text-[#999] font-medium">Status</dt>
          <dd class="text-[#111]">
            <span class="inline-flex items-center border border-[#111] text-[10px] font-semibold tracking-[0.08em] uppercase px-1.5 py-0.5 leading-none mr-2">Live</span>
            Fetching from this server in real time.
          </dd>
        </dl>
      </div>

      <!-- Introduction -->
      <div class="prose max-w-none mb-10">
        <p>
          <code>agents.txt</code> is Layer 4 of the agent-readiness stack. The three layers beneath it govern crawler access policy, page inventory, and curated content for LLMs. None of those four files replaces another; together they form the discovery and content surface a compliant agent reads when it first encounters a site. This page fetches each file live from this server and shows what it carries, plus a fifth check covering the cross-cutting §4.5 serving headers.
        </p>

        <h2>The stack at a glance</h2>
        <table>
          <thead>
            <tr><th>Layer</th><th>File</th><th>Spec</th><th>What it carries</th></tr>
          </thead>
          <tbody>
            <tr><td class="font-mono">1</td><td><code>/robots.txt</code></td><td>RFC 9309</td><td>Crawler access policy. Who is allowed and disallowed.</td></tr>
            <tr><td class="font-mono">2</td><td><code>/sitemap.xml</code></td><td>sitemaps.org 0.9</td><td>Page inventory. Every URL the site wants indexed.</td></tr>
            <tr><td class="font-mono">3</td><td><code>/llms.txt</code></td><td>llmstxt.org</td><td>Curated reading list for LLM inference, organised by section.</td></tr>
            <tr><td class="font-mono">3</td><td><code>/llms-full.txt</code></td><td>llmstxt.org</td><td>Expanded companion. Same structure, page content inlined.</td></tr>
            <tr><td class="font-mono">4</td><td><code>/agents.txt</code></td><td>agents.txt v{SPEC_VERSION}</td><td>Agent capability declaration. See the other demos.</td></tr>
          </tbody>
        </table>

        <h2>Retrieval flow</h2>
        <table>
          <thead>
            <tr><th>Step</th><th>File</th><th>Purpose</th></tr>
          </thead>
          <tbody>
            <tr><td class="font-mono">0</td><td><code>/robots.txt</code></td><td>Crawler policy and the spec §4.3 <code>Allow: /agents.txt</code> discovery hint</td></tr>
            <tr><td class="font-mono">1</td><td><code>/sitemap.xml</code></td><td>Page inventory; URL count and root element shape</td></tr>
            <tr><td class="font-mono">2</td><td><code>/llms.txt</code></td><td>Link inventory: curated page list with descriptions</td></tr>
            <tr><td class="font-mono">3</td><td><code>/llms-full.txt</code></td><td>Expanded form: page content inlined under each heading</td></tr>
            <tr><td class="font-mono">4</td><td>§4.5 headers</td><td>HEAD on <code>/agents.txt</code> and <code>/agents.json</code> to verify Content-Type, CORS, Cache-Control</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Demo runner -->
      <div class="border border-[#e5e5e5]">
        <div class="flex items-center justify-between px-5 py-4 border-b border-[#e5e5e5]">
          <div>
            <p class="text-sm font-semibold text-[#111]">Discovery & content runner</p>
            <p class="text-xs text-[#999] mt-0.5">Static files · fetched live from this server</p>
          </div>
          <button
            id="run-btn"
            class="flex items-center gap-2 border border-[#111] text-xs font-semibold tracking-[0.06em] uppercase px-4 py-2 hover:bg-[#111] hover:text-white transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
          >
            <span id="run-btn-label">Run</span>
          </button>
        </div>

        <div id="steps" class="divide-y divide-[#e5e5e5]">
          {[
            ['0', 'Crawler policy',     'GET /robots.txt'],
            ['1', 'Page inventory',     'GET /sitemap.xml'],
            ['2', 'Link inventory',     'GET /llms.txt'],
            ['3', 'Expanded content',   'GET /llms-full.txt'],
            ['4', '§4.5 headers check', 'HEAD /agents.txt · HEAD /agents.json'],
          ].map(([num, label, hint]) => (
            <div class="step" data-step={num} data-state="idle">
              <div class="flex items-start justify-between gap-4 px-5 py-3">
                <div class="flex items-start gap-3 min-w-0">
                  <span class="step-indicator font-mono text-[10px] text-[#ccc] mt-0.5 shrink-0 w-4">·</span>
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-[#bbb] step-label">{label}</p>
                    <p class="font-mono text-[11px] text-[#ccc] step-hint mt-0.5">{hint}</p>
                  </div>
                </div>
                <span class="step-badge font-mono text-[10px] text-[#ccc] shrink-0 mt-0.5"></span>
              </div>
              <div class="step-body hidden px-5 pb-4">
                <pre class="step-output bg-[#f6f6f6] border border-[#e5e5e5] text-[11px] font-mono text-[#333] p-4 overflow-x-auto whitespace-pre-wrap leading-relaxed m-0 max-h-80"></pre>
              </div>
            </div>
          ))}
        </div>

        <div id="result-banner" class="hidden px-5 py-4 border-t border-[#e5e5e5]">
          <p id="result-text" class="text-sm font-medium text-[#111]"></p>
          <p class="text-xs text-[#999] mt-1">Every file is served statically and regenerated from <code>agentsjson.config.js</code> on each deploy. The §4.5 headers come from <code>public/_headers</code>, also herald-managed.</p>
        </div>
      </div>

      <!-- Technical notes -->
      <div class="prose max-w-none mt-12">
        <h2>Technical notes</h2>

        <h3>Layer 1: robots.txt (RFC 9309)</h3>
        <p>
          <code>robots.txt</code> is the oldest piece of this stack. It tells crawlers which paths they may visit. agents.txt v{SPEC_VERSION} §4.3 piggy-backs on it: a compliant site SHOULD include <code>Allow: /agents.txt</code> in its default <code>User-agent: *</code> block, both to grant explicit access and to expose the file's existence to any crawler that reads <code>robots.txt</code>. No separate discovery directive (<code>Agents-Txt:</code>) is emitted because <code>agents.txt</code> always lives at the canonical path.
        </p>
        <p>
          A site MAY also include a <code>Content-Signal:</code> directive (IETF AIPREF draft, CC0) to declare AI training and indexing preferences. That signal is distinct from agent <em>interaction</em> capabilities and is independent of <code>agents.txt</code>.
        </p>

        <h3>Layer 2: sitemap.xml (sitemaps.org 0.9)</h3>
        <p>
          A flat XML inventory of every URL the site wants indexed. <code>&lt;urlset&gt;</code> root for a single sitemap, <code>&lt;sitemapindex&gt;</code> root for an index that points at multiple sitemaps. Per the protocol, a single sitemap may carry at most 50 000 URLs and 50 MB uncompressed; larger sites split into an index. Each <code>&lt;url&gt;</code> element MUST contain a <code>&lt;loc&gt;</code>; the optional <code>&lt;lastmod&gt;</code>, <code>&lt;changefreq&gt;</code>, and <code>&lt;priority&gt;</code> fields carry update hints. Out of scope for an agents.txt demo; herald's <code>validateSitemapXml</code> covers the full protocol if you need to audit your own.
        </p>

        <h3>Layer 3: llms.txt and llms-full.txt (llmstxt.org)</h3>
        <p>
          <code>/llms.txt</code> is the editorially curated reading list: which pages an LLM should read first to understand the site, grouped into sections by topic. <code>/llms-full.txt</code> is the expanded companion: the same structure, but with each linked page's markdown content inlined under its heading.
        </p>
        <p>
          Both files are generated from the same <code>AgenticConfig</code> object that drives <code>agents.txt</code> and the payment middleware. The <code>content.driver</code> discriminated union controls how pages are discovered. <code>sitemap</code> fetches <code>/sitemap.xml</code> and groups pages by path prefix. <code>firecrawl</code> calls the Firecrawl API and produces richer titles and natural groupings. <code>static</code> accepts a hardcoded page list, useful for Jamstack sites without a runtime sitemap. <code>manual</code> accepts a pre-built sections array for full editorial control.
        </p>
        <p>
          When a Firecrawl driver is configured under <code>content.fullTxt.driver</code>, <code>generateLlmsFullTxt</code> scrapes each page's markdown via <code>POST https://api.firecrawl.dev/v2/scrape</code> with <code>onlyMainContent: true</code>, batching five at a time. The <code>fullTxt.driver</code> field is an independent driver, so a site can point <code>llms.txt</code> at the marketing site (<code>sitemap</code> driver) and <code>llms-full.txt</code> at a docs subdomain (Firecrawl driver). Without Firecrawl, <code>llms-full.txt</code> falls back to the same link-list format as <code>llms.txt</code>.
        </p>

        <h3>§4.5 serving headers (the cross-cutting layer)</h3>
        <p>
          agents.txt §4.5 mandates four response-header rules on <code>/agents.txt</code> and <code>/agents.json</code>: a <code>Content-Type</code> with charset for <code>agents.txt</code>, an <code>Access-Control-Allow-Origin: *</code> on both files (load-bearing for browser-context agent clients fetching cross-origin), and a SHOULD-set <code>Cache-Control</code>. Static-asset pipelines on most hosting platforms do not set these by default, so herald emits a platform-specific config file (<code>_headers</code> for Cloudflare and Netlify, <code>vercel.json#headers[]</code> for Vercel) carrying the rules. The same generator also walks <code>config.a2a.cards</code> and <code>config.ucp.profiles</code>, emitting matching entries for every same-origin AgentCard or UCP profile path.
        </p>
        <p>
          The rule splits on <em>how</em> the path is served, not on what it contains. Static files (anything under <code>public/</code>, including <code>public/.well-known/*</code>) get headers from <code>_headers</code>. Dynamic worker routes (the agent-auth <code>/.well-known/agent-configuration</code>, the proxied <code>/mcp</code>, the synthetic <code>/x402</code> and <code>/mpp</code>) set their headers programmatically; a static <code>_headers</code> entry for those paths is silently ignored. Both patterns are exercised in this deployment.
        </p>
        <p class="text-xs text-[#777] border-l-2 border-[#e5e5e5] pl-3">
          Note on local dev: <code>astro dev</code> uses Vite's static handler, which does not parse <code>public/_headers</code>. Running step 4 against <code>http://localhost:4321</code> will report a §4.5 fail (no <code>charset=utf-8</code>, no CORS, <code>Cache-Control: no-cache</code>). That is expected and is not a problem with the site config; the headers ship at deploy time through Cloudflare's static asset pipeline. The same check against the production origin passes.
        </p>

        <h3>How this all composes</h3>
        <p>
          A first-contact agent reads <code>/robots.txt</code> to learn whether it is permitted, follows <code>Allow: /agents.txt</code> to find the capability declaration, fetches <code>/agents.txt</code> (or the structured <code>/agents.json</code>) to discover what protocols this site speaks, and uses <code>/llms.txt</code> if it needs curated content for inference. <code>/sitemap.xml</code> serves the same crawler audience it always has. Each file is generated from the same config object, so the four layers cannot drift relative to each other.
        </p>
      </div>

    </div>
  </div>

  <!-- Footer -->
  <footer class="border-t border-[#e5e5e5] mt-4">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="text-xs text-[#999]">
        <span class="font-mono font-semibold text-[#555]">agents.txt</span>
        {' '}Standard v{SPEC_VERSION} ·{' '}
        <a href="/spec" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Spec</a>
        {' '}·{' '}
        <a href="/demo" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">All demos</a>
      </div>
      <p class="text-xs text-[#bbb]">CC0 (spec) · Apache 2.0 (code). Anyone may implement the standard without restriction.</p>
    </div>
  </footer>
</BaseLayout>

<script>
function getStep(num: string) {
  return document.querySelector<HTMLElement>(`.step[data-step="${num}"]`)!;
}

function setRunning(num: string) {
  const el = getStep(num);
  el.dataset.state = 'running';
  el.querySelector<HTMLElement>('.step-indicator')!.textContent = '▸';
  el.querySelector<HTMLElement>('.step-label')!.classList.replace('text-[#bbb]', 'text-[#111]');
  el.querySelector<HTMLElement>('.step-hint')!.classList.replace('text-[#ccc]', 'text-[#777]');
  el.querySelector<HTMLElement>('.step-badge')!.textContent = '···';
  el.querySelector<HTMLElement>('.step-body')!.classList.remove('hidden');
  el.querySelector<HTMLElement>('.step-output')!.textContent = 'Running…';
}

function setDone(num: string, output: string, badge = '') {
  const el = getStep(num);
  el.dataset.state = 'done';
  el.querySelector<HTMLElement>('.step-indicator')!.textContent = '✓';
  el.querySelector<HTMLElement>('.step-indicator')!.className = 'step-indicator font-mono text-[10px] text-[#111] mt-0.5 shrink-0 w-4';
  el.querySelector<HTMLElement>('.step-badge')!.textContent = badge;
  el.querySelector<HTMLElement>('.step-badge')!.className = 'step-badge font-mono text-[10px] text-[#555] shrink-0 mt-0.5';
  el.querySelector<HTMLElement>('.step-body')!.classList.remove('hidden');
  el.querySelector<HTMLElement>('.step-output')!.textContent = output;
}

function setError(num: string, message: string) {
  const el = getStep(num);
  el.dataset.state = 'error';
  el.querySelector<HTMLElement>('.step-indicator')!.textContent = '✕';
  el.querySelector<HTMLElement>('.step-badge')!.textContent = 'error';
  el.querySelector<HTMLElement>('.step-body')!.classList.remove('hidden');
  el.querySelector<HTMLElement>('.step-output')!.textContent = message;
}

function truncate(text: string, limit = 1200): string {
  if (text.length <= limit) return text;
  return text.slice(0, limit) + `\n\n… (${text.length.toLocaleString()} bytes total; full content at this URL)`;
}

function countMatches(text: string, re: RegExp): number {
  return (text.match(re) ?? []).length;
}

async function run() {
  const btn = document.getElementById('run-btn')!;
  const label = document.getElementById('run-btn-label')!;
  const banner = document.getElementById('result-banner')!;
  const resultText = document.getElementById('result-text')!;

  btn.setAttribute('disabled', '');
  label.textContent = 'Running…';
  banner.classList.add('hidden');
  resultText.className = 'text-sm font-medium text-[#111]';

  document.querySelectorAll<HTMLElement>('.step').forEach(el => {
    el.dataset.state = 'idle';
    el.querySelector<HTMLElement>('.step-indicator')!.textContent = '·';
    el.querySelector<HTMLElement>('.step-indicator')!.className = 'step-indicator font-mono text-[10px] text-[#ccc] mt-0.5 shrink-0 w-4';
    el.querySelector<HTMLElement>('.step-label')!.className = 'text-sm font-medium text-[#bbb] step-label';
    el.querySelector<HTMLElement>('.step-hint')!.className = 'font-mono text-[11px] text-[#ccc] step-hint mt-0.5';
    el.querySelector<HTMLElement>('.step-badge')!.textContent = '';
    el.querySelector<HTMLElement>('.step-badge')!.className = 'step-badge font-mono text-[10px] text-[#ccc] shrink-0 mt-0.5';
    el.querySelector<HTMLElement>('.step-body')!.classList.add('hidden');
    el.querySelector<HTMLElement>('.step-output')!.textContent = '';
  });

  const origin = window.location.origin;

  try {
    // ── Step 0: robots.txt ───────────────────────────────────────────────────
    setRunning('0');
    const robotsRes = await fetch(`${origin}/robots.txt`);
    const robotsText = await robotsRes.text();
    const allowsAgentsTxt = /^\s*Allow:\s*\/agents\.txt\b/m.test(robotsText);
    const hasContentSignal = /^\s*Content-Signal:/m.test(robotsText);
    const userAgents = countMatches(robotsText, /^\s*User-agent:/gm);
    const robotsSummary = [
      `Allow: /agents.txt  ${allowsAgentsTxt ? '✓ present (§4.3)' : '✕ missing (recommended by §4.3)'}`,
      `Content-Signal:     ${hasContentSignal ? '✓ present' : 'not declared'}`,
      `User-agent: blocks  ${userAgents}`,
    ].join('\n');
    setDone('0',
      `GET /robots.txt\nStatus: ${robotsRes.status}\n\n${robotsSummary}\n\n${truncate(robotsText)}`,
      `${robotsRes.status} · ${robotsText.length.toLocaleString()} bytes`,
    );

    // ── Step 1: sitemap.xml ──────────────────────────────────────────────────
    setRunning('1');
    const sitemapRes = await fetch(`${origin}/sitemap.xml`);
    const sitemapText = await sitemapRes.text();
    const isUrlset = /<urlset[\s>]/.test(sitemapText);
    const isIndex = /<sitemapindex[\s>]/.test(sitemapText);
    const urlCount = countMatches(sitemapText, /<loc>/g);
    const sitemapSummary = [
      `Root:        ${isIndex ? '<sitemapindex>' : isUrlset ? '<urlset>' : '(neither; non-conformant)'}`,
      `<loc> count: ${urlCount}`,
      `Format:      sitemaps.org 0.9`,
    ].join('\n');
    setDone('1',
      `GET /sitemap.xml\nStatus: ${sitemapRes.status}\nContent-Type: ${sitemapRes.headers.get('content-type') ?? '(missing)'}\n\n${sitemapSummary}\n\n${truncate(sitemapText)}`,
      `${sitemapRes.status} · ${urlCount} URL${urlCount === 1 ? '' : 's'}`,
    );

    // ── Step 2: llms.txt ─────────────────────────────────────────────────────
    setRunning('2');
    const llmsRes = await fetch(`${origin}/llms.txt`);
    const llmsText = await llmsRes.text();
    setDone('2',
      `GET /llms.txt\nStatus: ${llmsRes.status}\nContent-Type: ${llmsRes.headers.get('content-type') ?? '(missing)'}\n\n${truncate(llmsText)}`,
      `${llmsRes.status} · ${llmsText.length.toLocaleString()} bytes`,
    );

    // ── Step 3: llms-full.txt ────────────────────────────────────────────────
    setRunning('3');
    const fullRes = await fetch(`${origin}/llms-full.txt`);
    const fullText = await fullRes.text();
    setDone('3',
      `GET /llms-full.txt\nStatus: ${fullRes.status}\nContent-Type: ${fullRes.headers.get('content-type') ?? '(missing)'}\n\n${truncate(fullText)}`,
      `${fullRes.status} · ${fullText.length.toLocaleString()} bytes`,
    );

    // ── Step 4: §4.5 headers check ──────────────────────────────────────────
    setRunning('4');
    const checkHeaders = async (path: string, expectedType: RegExp) => {
      const res = await fetch(`${origin}${path}`, { method: 'HEAD' });
      const ct = res.headers.get('content-type') ?? '(missing)';
      const cors = res.headers.get('access-control-allow-origin') ?? '(missing)';
      const cache = res.headers.get('cache-control') ?? '(missing)';
      const ctOk = expectedType.test(ct);
      const corsOk = cors === '*';
      const cacheOk = !!res.headers.get('cache-control');
      return {
        path,
        status: res.status,
        ct, cors, cache,
        ctOk, corsOk, cacheOk,
      };
    };

    const txtCheck = await checkHeaders('/agents.txt', /^text\/plain\s*;\s*charset\s*=\s*utf-8\b/i);
    const jsonCheck = await checkHeaders('/agents.json', /^application\/json\b/i);

    const renderCheck = (c: {
      path: string; status: number; ct: string; cors: string; cache: string;
      ctOk: boolean; corsOk: boolean; cacheOk: boolean;
    }) => [
      `HEAD ${c.path}  →  ${c.status}`,
      `  Content-Type:                 ${c.ct}  ${c.ctOk ? '✓' : '✕'}`,
      `  Access-Control-Allow-Origin:  ${c.cors}  ${c.corsOk ? '✓ (MUST be *)' : '✕'}`,
      `  Cache-Control:                ${c.cache}  ${c.cacheOk ? '✓' : '(SHOULD be set)'}`,
    ].join('\n');

    const allOk = txtCheck.ctOk && txtCheck.corsOk && jsonCheck.ctOk && jsonCheck.corsOk;
    const isLocalhost = /^https?:\/\/(localhost|127\.0\.0\.1|\[::1\])/i.test(origin);
    const envNote = isLocalhost
      ? '\n\nNote: this looks like a localhost dev preview. astro dev (Vite) does not honor public/_headers; the §4.5 rules only apply once the site is deployed behind Cloudflare\'s static asset pipeline (or the equivalent platform headers file). Run this same check against the production origin to see the real result.'
      : '';
    const envBadge = allOk ? 'pass' : (isLocalhost ? 'dev (expected fail)' : 'fail');
    setDone('4',
      `§4.5 serving headers (HEAD requests, no body)\n\n${renderCheck(txtCheck)}\n\n${renderCheck(jsonCheck)}\n\nOverall: ${allOk ? 'pass' : 'fail'}${envNote}`,
      envBadge,
    );

    const resultSuffix = allOk
      ? '§4.5 pass'
      : (isLocalhost ? '§4.5 fail (expected on localhost; passes in production)' : '§4.5 fail');
    resultText.textContent = `${urlCount} URL${urlCount === 1 ? '' : 's'} in sitemap · ${llmsText.length.toLocaleString()} bytes (llms.txt) · ${fullText.length.toLocaleString()} bytes (llms-full.txt) · ${resultSuffix}.`;
    banner.classList.remove('hidden');

  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    const running = document.querySelector<HTMLElement>('.step[data-state="running"]');
    if (running) setError(running.dataset.step!, msg);
    resultText.textContent = 'Retrieval interrupted. See step above for details.';
    resultText.classList.add('text-[#c00]');
    banner.classList.remove('hidden');
  } finally {
    btn.removeAttribute('disabled');
    label.textContent = 'Run again';
  }
}

document.getElementById('run-btn')!.addEventListener('click', run);
</script>
