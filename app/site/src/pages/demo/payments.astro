---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { SPEC_VERSION } from '../../config';
---

<BaseLayout
  title="Payments Demo · agents.txt"
  description="Live demonstration of the x402 payment protocol on Base and Solana. The payment configuration is read from agents.json and a gated endpoint is requested without credentials, returning a real 402 with machine-readable payment requirements for both chains."
  canonicalUrl="https://agentstxt.dev/demo/payments"
>
  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-white border-b border-[#e5e5e5]">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="font-mono text-sm font-semibold tracking-tight text-[#111] no-underline whitespace-nowrap">
          agents.txt
        </a>
        <span class="text-[#ccc] select-none">/</span>
        <a href="/demo" class="text-sm text-[#555] hover:text-[#111] transition-colors no-underline whitespace-nowrap">Demos</a>
        <span class="text-[#ccc] select-none">/</span>
        <span class="text-sm text-[#111] whitespace-nowrap">Payments</span>
      </div>
      <div class="flex items-center gap-5 shrink-0">
        <a href="/agents.txt" class="font-mono text-xs text-[#555] hover:text-[#111] transition-colors no-underline">agents.txt</a>
        <a href="/agents.json" class="font-mono text-xs text-[#555] hover:text-[#111] transition-colors no-underline">agents.json</a>
        <a href="/demo" class="text-xs font-medium text-[#111] no-underline border-b border-[#111]">Demo</a>
        <span class="hidden sm:block text-[#ddd] select-none">|</span>
        <a href="https://github.com/agentstxt/agents.txt" target="_blank" rel="noopener noreferrer"
          class="flex text-xs text-[#555] hover:text-[#111] transition-colors no-underline items-center gap-1">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </header>

  <!-- Page body -->
  <div class="max-w-[1280px] mx-auto px-6 sm:px-10 pt-12 pb-24">
    <div class="max-w-[72ch]">

      <!-- Cover -->
      <div class="mb-10 pb-8 border-b border-[#e5e5e5]">
        <h1 class="text-2xl font-bold tracking-tight text-[#111] mb-1">
          x402 Payment Protocol: Live Demonstration
        </h1>
        <p class="text-sm text-[#777] font-mono mb-6">x402 v2 · USDC · EVM (any chain) + Solana · Public facilitator</p>
        <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-sm">
          <dt class="text-[#999] font-medium">Protocol</dt>
          <dd class="text-[#111]">
            <a href="https://x402.org" target="_blank" rel="noopener noreferrer"
              class="font-mono underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all">
              x402.org
            </a>
          </dd>
          <dt class="text-[#999] font-medium">Networks</dt>
          <dd class="font-mono text-[#111]">Base · Ethereum · Avalanche · Solana</dd>
          <dt class="text-[#999] font-medium">Settlement</dt>
          <dd class="font-mono text-[#111]">x402.org/facilitator/settle</dd>
          <dt class="text-[#999] font-medium">Status</dt>
          <dd class="text-[#111]">
            <span class="inline-flex items-center border border-[#111] text-[10px] font-semibold tracking-[0.08em] uppercase px-1.5 py-0.5 leading-none mr-2">Live</span>
            Real 402 and real settlement. Treasury address is a placeholder until replaced.
          </dd>
        </dl>
      </div>

      <!-- Introduction -->
      <div class="prose max-w-none mb-10">
        <p>
          This page demonstrates the x402 v2 payment negotiation sequence. The payment configuration declared by this server in <code>agents.json</code> is read first, then a gated endpoint is requested without credentials. The server responds with a real <code>402 Payment Required</code> containing four <code>accepts[]</code> entries for Base, Ethereum, Avalanche (EVM), and Solana, giving an x402-capable agent the choice of network based on its available wallet.
        </p>
        <p>
          On EVM chains, the agent constructs an EIP-3009 off-chain transfer authorization and does not broadcast any transaction itself. On Solana, the agent builds and signs a full SPL token transfer transaction and includes the serialized bytes. In both cases the agent sends the signed payload in the <code>Payment-Signature</code> header, and the public facilitator at <code>x402.org/facilitator/settle</code> handles on-chain submission. No API key or private key is required on the server.
        </p>
        <p class="text-xs text-[#777] border-l-2 border-[#e5e5e5] pl-3 italic">
          Note: <code>agents.json</code> is the optional pre-screening layer. An agent may also call the gated endpoint directly without reading <code>agents.json</code> first; the spec does not mandate discovery before requests. The two steps below are independent. Production deployments declare what they serve and serve what they declare; demo deployments may diverge to expose the wire shape regardless.
        </p>

        <h2>Protocol flow</h2>
        <table>
          <thead>
            <tr><th>Step</th><th>Action</th><th>Result</th></tr>
          </thead>
          <tbody>
            <tr><td class="font-mono">0</td><td>Read payment configuration from <code>agents.json</code></td><td class="text-[#999]">per-protocol blocks, chains, declared pricing</td></tr>
            <tr><td class="font-mono">1</td><td>Request gated resource (no <code>Payment-Signature</code> header)</td><td>402 · four <code>accepts[]</code> entries (Base · ETH · Avax · Solana)</td></tr>
            <tr><td class="font-mono text-[#ccc]">—</td><td class="text-[#999]">Agent selects a network, constructs and signs payment payload</td><td class="text-[#999]">off-chain · not executable in browser</td></tr>
            <tr><td class="font-mono text-[#ccc]">—</td><td class="text-[#999]">Agent retries with <code>Payment-Signature</code> · public facilitator settles · responds 200</td><td class="text-[#999]">200 · <code>X-Payment-Response</code></td></tr>
          </tbody>
        </table>
      </div>

      <!-- Demo runner -->
      <div class="border border-[#e5e5e5]">
        <div class="flex items-center justify-between px-5 py-4 border-b border-[#e5e5e5]">
          <div>
            <p class="text-sm font-semibold text-[#111]">Payment negotiation runner</p>
            <p class="text-xs text-[#999] mt-0.5">Live requests · 402 served by this server · no payment executed</p>
          </div>
          <button
            id="run-btn"
            class="flex items-center gap-2 border border-[#111] text-xs font-semibold tracking-[0.06em] uppercase px-4 py-2 hover:bg-[#111] hover:text-white transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
          >
            <span id="run-btn-label">Run</span>
          </button>
        </div>

        <div id="steps" class="divide-y divide-[#e5e5e5]">
          {[
            ['0', 'Payment configuration', 'GET /agents.json · payments{}'],
            ['1', 'Payment negotiation',   'GET /payment-test  (no Payment-Signature) → expect 402'],
          ].map(([num, label, hint]) => (
            <div class="step" data-step={num} data-state="idle">
              <div class="flex items-start justify-between gap-4 px-5 py-3">
                <div class="flex items-start gap-3 min-w-0">
                  <span class="step-indicator font-mono text-[10px] text-[#ccc] mt-0.5 shrink-0 w-4">·</span>
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-[#bbb] step-label">{label}</p>
                    <p class="font-mono text-[11px] text-[#ccc] step-hint mt-0.5">{hint}</p>
                  </div>
                </div>
                <span class="step-badge font-mono text-[10px] text-[#ccc] shrink-0 mt-0.5"></span>
              </div>
              <div class="step-body hidden px-5 pb-4">
                <pre class="step-output bg-[#f6f6f6] border border-[#e5e5e5] text-[11px] font-mono text-[#333] p-4 overflow-x-auto whitespace-pre-wrap leading-relaxed m-0"></pre>
              </div>
            </div>
          ))}
        </div>

        <div id="result-banner" class="hidden px-5 py-4 border-t border-[#e5e5e5]">
          <p id="result-text" class="text-sm font-medium text-[#111]"></p>
          <p class="text-xs text-[#999] mt-1">The 402 above is the actual response served by this server. To complete a payment, use an x402-capable agent or the <a href="https://github.com/coinbase/x402" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">x402 SDK</a>.</p>
        </div>
      </div>

      <!-- Chain comparison -->
      <div class="prose max-w-none mt-12">
        <h2>EVM vs Solana: payment mechanism differences</h2>
        <table>
          <thead>
            <tr><th></th><th>EVM (Base · ETH · Avax)</th><th>Solana</th></tr>
          </thead>
          <tbody>
            <tr><td class="font-medium">Network string (CAIP-2)</td><td class="font-mono text-[11px]">eip155:8453 / eip155:1 / eip155:43114</td><td class="font-mono text-[11px]">solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp</td></tr>
            <tr><td class="font-medium">Asset identifier</td><td>ERC-20 contract address (<code>0x…</code>)</td><td>SPL token mint address (base58)</td></tr>
            <tr><td class="font-medium">Recipient field</td><td>EVM wallet address (<code>0x…</code>)</td><td>Associated Token Account (ATA) address</td></tr>
            <tr><td class="font-medium">Payment primitive</td><td>EIP-3009 off-chain transfer authorization</td><td>Full signed SPL token transfer transaction</td></tr>
            <tr><td class="font-medium">Who broadcasts</td><td>Public facilitator (x402.org/facilitator/settle)</td><td>Public facilitator (x402.org/facilitator/settle)</td></tr>
            <tr><td class="font-medium">Agent signs</td><td>Authorization struct (no tx broadcast)</td><td>Full transaction including blockhash</td></tr>
            <tr><td class="font-medium">Settlement</td><td>Public facilitator (x402.org/facilitator/settle)</td><td>Public facilitator (x402.org/facilitator/settle)</td></tr>
            <tr><td class="font-medium">Payment-Signature payload</td><td class="font-mono text-[11px]">&#123; accepted: &#123; … &#125;, signature, authorization &#125;</td><td class="font-mono text-[11px]">&#123; accepted: &#123; … &#125;, serializedTransaction: "…" &#125;</td></tr>
          </tbody>
        </table>

        <h2>Protocol reference</h2>

        <h3>EVM: <code>Payment-Signature</code> payload (EIP-3009)</h3>
        <p>
          The agent constructs an EIP-3009 <code>transferWithAuthorization</code> struct (a signed off-chain USDC transfer approval) and does not broadcast any transaction itself. The signed payload is base64-encoded and sent in the <code>Payment-Signature</code> header. The public facilitator at <code>x402.org/facilitator/settle</code> submits the transfer on-chain after verifying the signature.
        </p>
        <pre><code>{`// Payment-Signature header value (base64-encoded JSON):
{
  "x402Version": 2,
  "scheme": "exact",
  "network": "eip155:8453",
  "accepted": {
    "scheme":  "exact",
    "network": "eip155:8453",
    "amount":  "1000",
    "asset":   "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
    "payTo":   "0x<treasury-address>",
    "maxTimeoutSeconds": 60
  },
  "signature": "0x2d6a7588…",
  "authorization": {
    "from":        "0x<payer-address>",
    "to":          "0x<recipient-address>",
    "value":       "1000",
    "validAfter":  "<unix-timestamp>",
    "validBefore": "<unix-timestamp>",
    "nonce":       "0x<random-32-bytes>"
  }
}`}</code></pre>

        <h3>Solana: <code>Payment-Signature</code> payload (serialized transaction)</h3>
        <p>
          The agent builds a full SPL token transfer transaction including the current blockhash, signs it with its wallet private key, and base64-encodes the serialized bytes. The blockhash requirement means the transaction has a limited validity window, typically around 90 seconds. The public facilitator handles RPC submission.
        </p>
        <pre><code>{`// Payment-Signature header value (base64-encoded JSON):
{
  "x402Version": 2,
  "scheme": "exact",
  "network": "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
  "accepted": {
    "scheme":  "exact",
    "network": "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
    "amount":  "1000",
    "asset":   "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v",
    "payTo":   "<treasury-ATA-address>",
    "maxTimeoutSeconds": 60
  },
  "serializedTransaction": "<base64-encoded-signed-transaction>"
}`}</code></pre>

        <h3>Settlement response: <code>X-Payment-Response</code></h3>
        <p>
          All chains return the same response envelope on success. The <code>transaction</code> field is the on-chain transaction hash: a hex string prefixed with <code>0x</code> on EVM chains, a base58 signature string on Solana.
        </p>
        <pre><code>{`{
  "success":     true,
  "transaction": "<on-chain-tx-hash-or-signature>",
  "network":     "eip155:8453" | "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
  "payer":       "<payer-address>"
}`}</code></pre>

      </div>

    </div>
  </div>

  <!-- Footer -->
  <footer class="border-t border-[#e5e5e5] mt-4">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="text-xs text-[#999]">
        <span class="font-mono font-semibold text-[#555]">agents.txt</span>
        {' '}Standard v{SPEC_VERSION} ·{' '}
        <a href="/" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Spec</a>
        {' '}·{' '}
        <a href="/demo" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">All demos</a>
      </div>
      <p class="text-xs text-[#bbb]">CC0 (spec) · Apache 2.0 (code). Anyone may implement the standard without restriction.</p>
    </div>
  </footer>
</BaseLayout>

<script>
function getStep(num: string) {
  return document.querySelector<HTMLElement>(`.step[data-step="${num}"]`)!;
}

function setRunning(num: string) {
  const el = getStep(num);
  el.dataset.state = 'running';
  el.querySelector<HTMLElement>('.step-indicator')!.textContent = '▸';
  el.querySelector<HTMLElement>('.step-label')!.classList.replace('text-[#bbb]', 'text-[#111]');
  el.querySelector<HTMLElement>('.step-hint')!.classList.replace('text-[#ccc]', 'text-[#777]');
  el.querySelector<HTMLElement>('.step-badge')!.textContent = '···';
  el.querySelector<HTMLElement>('.step-body')!.classList.remove('hidden');
  el.querySelector<HTMLElement>('.step-output')!.textContent = 'Running…';
}

function setDone(num: string, output: string, badge = '') {
  const el = getStep(num);
  el.dataset.state = 'done';
  el.querySelector<HTMLElement>('.step-indicator')!.textContent = '✓';
  el.querySelector<HTMLElement>('.step-indicator')!.className = 'step-indicator font-mono text-[10px] text-[#111] mt-0.5 shrink-0 w-4';
  el.querySelector<HTMLElement>('.step-badge')!.textContent = badge;
  el.querySelector<HTMLElement>('.step-badge')!.className = 'step-badge font-mono text-[10px] text-[#555] shrink-0 mt-0.5';
  el.querySelector<HTMLElement>('.step-body')!.classList.remove('hidden');
  el.querySelector<HTMLElement>('.step-output')!.textContent = output;
}

function setError(num: string, message: string) {
  const el = getStep(num);
  el.dataset.state = 'error';
  el.querySelector<HTMLElement>('.step-indicator')!.textContent = '✕';
  el.querySelector<HTMLElement>('.step-badge')!.textContent = 'error';
  el.querySelector<HTMLElement>('.step-body')!.classList.remove('hidden');
  el.querySelector<HTMLElement>('.step-output')!.textContent = message;
}

const fmt = (obj: unknown) => JSON.stringify(obj, null, 2);

async function run() {
  const btn = document.getElementById('run-btn')!;
  const label = document.getElementById('run-btn-label')!;
  const banner = document.getElementById('result-banner')!;
  const resultText = document.getElementById('result-text')!;

  btn.setAttribute('disabled', '');
  label.textContent = 'Running…';
  banner.classList.add('hidden');
  resultText.className = 'text-sm font-medium text-[#111]';

  document.querySelectorAll<HTMLElement>('.step').forEach(el => {
    el.dataset.state = 'idle';
    el.querySelector<HTMLElement>('.step-indicator')!.textContent = '·';
    el.querySelector<HTMLElement>('.step-indicator')!.className = 'step-indicator font-mono text-[10px] text-[#ccc] mt-0.5 shrink-0 w-4';
    el.querySelector<HTMLElement>('.step-label')!.className = 'text-sm font-medium text-[#bbb] step-label';
    el.querySelector<HTMLElement>('.step-hint')!.className = 'font-mono text-[11px] text-[#ccc] step-hint mt-0.5';
    el.querySelector<HTMLElement>('.step-badge')!.textContent = '';
    el.querySelector<HTMLElement>('.step-badge')!.className = 'step-badge font-mono text-[10px] text-[#ccc] shrink-0 mt-0.5';
    el.querySelector<HTMLElement>('.step-body')!.classList.add('hidden');
    el.querySelector<HTMLElement>('.step-output')!.textContent = '';
  });

  const origin = window.location.origin;

  try {
    // ── Step 0: Payment configuration from agents.json ────────────────────────
    // Informational only. agents.json is the optional pre-screening layer; an
    // agent may also hit /payment-test directly. We always proceed to step 1.
    setRunning('0');
    const agentsRes = await fetch(`${origin}/agents.json`);
    const agentsJson = await agentsRes.json() as {
      payments?: {
        x402?: { chains?: string[] };
        mpp?: { methods?: string[] };
        required?: boolean;
        pricing?: { amount?: string; currency?: string };
      };
    };
    const payments = agentsJson.payments;
    const chains = payments?.x402?.chains ?? [];
    const declaredProtocols = payments
      ? (Object.keys(payments).filter((k) => k === 'x402' || k === 'mpp'))
      : [];
    const paymentsDeclared = declaredProtocols.length > 0;
    const paymentSummary = paymentsDeclared
      ? [
          `declared      yes`,
          `protocols     ${declaredProtocols.join(', ')}`,
          `chains        ${chains.join(', ') || '(none)'}`,
        ].join('\n')
      : [
          `declared      no`,
          ``,
          `agents.json does not advertise payments on this deployment.`,
          `An agent that pre-screens via discovery would skip a paid request.`,
          `The demo proceeds anyway to show the wire shape that /payment-test`,
          `serves regardless of declaration (placeholder treasury addresses in dev).`,
        ].join('\n');
    setDone('0',
      `GET /agents.json · payments{}\n\n${paymentSummary}\n\nFull response:\n${fmt(agentsJson)}`,
      paymentsDeclared ? `${chains.length} chain${chains.length !== 1 ? 's' : ''}` : 'not declared',
    );

    // ── Step 1: Payment negotiation — hit /payment-test without Payment-Signature
    // Always runs, even if Step 0 reported no declaration. The endpoint is the
    // implementation layer; declaration is the advertisement layer; they agree
    // in production and may diverge in dev/demo deployments.
    setRunning('1');
    const paymentRes = await fetch(`${origin}/payment-test`);
    const paymentBody = await paymentRes.json() as {
      x402Version?: number;
      error?: string;
      accepts?: Array<{
        network?: string;
        amount?: string;
        asset?: string;
        payTo?: string;
        description?: string;
        scheme?: string;
      }>;
    };

    if (paymentRes.status !== 402) {
      throw new Error(`Expected 402, got ${paymentRes.status}:\n${fmt(paymentBody)}`);
    }

    const accepts = paymentBody.accepts ?? [];
    const acceptsSummary = accepts.length > 0
      ? accepts.map((a, i) => {
          const amountUsdc = a.amount
            ? (parseInt(a.amount, 10) / 1_000_000).toFixed(3)
            : '?';
          return [
            `accepts[${i}]: ${a.network}`,
            `  scheme   ${a.scheme}`,
            `  amount   ${amountUsdc} USDC`,
            `  asset    ${a.asset}`,
            `  payTo    ${a.payTo}`,
          ].join('\n');
        }).join('\n\n')
      : '(no accepts[] entries — endpoint emits a 402 without x402 negotiation)';

    setDone('1',
      `GET /payment-test  (no Payment-Signature header)\n\n` +
      `Status  ${paymentRes.status} Payment Required\n\n` +
      `${acceptsSummary}\n\nFull 402 body:\n${fmt(paymentBody)}`,
      `${paymentRes.status} · ${accepts.length} option${accepts.length !== 1 ? 's' : ''}`,
    );

    const networks = accepts.map(a => a.network).filter(Boolean).join(' · ');
    if (accepts.length > 0) {
      resultText.textContent = paymentsDeclared
        ? `Payment requirements received: ${accepts.length} network option${accepts.length !== 1 ? 's' : ''} (${networks}). An x402-capable agent selects one and constructs the appropriate payment payload.`
        : `Endpoint returned a 402 with ${accepts.length} accepts[] option${accepts.length !== 1 ? 's' : ''} (${networks}) even though agents.json declares no payments. The endpoint serves placeholder treasury addresses in dev for wire-shape demonstration; production deployments should declare what they serve.`;
    } else {
      resultText.textContent = `Endpoint returned a 402 but no accepts[] were present. This deployment may have payments disabled at the worker level. The wire shape is still visible above.`;
    }
    banner.classList.remove('hidden');

  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    const running = document.querySelector<HTMLElement>('.step[data-state="running"]');
    if (running) setError(running.dataset.step!, msg);
    resultText.textContent = 'Flow interrupted. See step above for details.';
    resultText.classList.add('text-[#c00]');
    banner.classList.remove('hidden');
  } finally {
    btn.removeAttribute('disabled');
    label.textContent = 'Run again';
  }
}

document.getElementById('run-btn')!.addEventListener('click', run);
</script>
