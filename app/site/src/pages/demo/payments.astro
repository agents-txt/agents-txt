---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavRight from '../../components/NavRight.astro';
import '../../styles/global.css';
import { SPEC_VERSION } from '../../config';
---

<BaseLayout
  title="Payments Demo · agents.txt"
  description="Live demonstration of the x402 payment protocol on Solana. The site declares x402 support in agents.json, then a synthetic gated route returns a real 402 Payment Required with the recipient wallet, as the spec requires."
  canonicalUrl="https://agentstxt.dev/demo/payments"
>
  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-white border-b border-[#e5e5e5]">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="font-mono text-sm font-semibold tracking-tight text-[#111] no-underline whitespace-nowrap">
          agents.txt
        </a>
        <span class="text-[#ccc] select-none">/</span>
        <a href="/demo" class="text-sm text-[#555] hover:text-[#111] transition-colors no-underline whitespace-nowrap">Demos</a>
        <span class="text-[#ccc] select-none">/</span>
        <span class="text-sm text-[#111] whitespace-nowrap">Payments</span>
      </div>
      <NavRight current="demo" />
    </div>
  </header>

  <!-- Page body -->
  <div class="max-w-[1280px] mx-auto px-6 sm:px-10 pt-12 pb-24">
    <div class="max-w-[72ch]">

      <!-- Cover -->
      <div class="mb-10 pb-8 border-b border-[#e5e5e5]">
        <h1 class="text-2xl font-bold tracking-tight text-[#111] mb-1">
          x402 Payment Protocol: Live Demonstration
        </h1>
        <p class="text-sm text-[#777] font-mono mb-6">x402 v2 · USDC on Solana · Public facilitator</p>
        <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-sm">
          <dt class="text-[#999] font-medium">Protocol</dt>
          <dd class="text-[#111]">
            <a href="https://x402.org" target="_blank" rel="noopener noreferrer"
              class="font-mono underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all">
              x402.org
            </a>
          </dd>
          <dt class="text-[#999] font-medium">Discovery</dt>
          <dd class="font-mono text-[#111]">/x402 · /agents.json payments.x402</dd>
          <dt class="text-[#999] font-medium">Network</dt>
          <dd class="font-mono text-[#111]">Solana mainnet (USDC)</dd>
          <dt class="text-[#999] font-medium">Transport</dt>
          <dd class="font-mono text-[#111]">HTTPS · HTTP 402 · X-Payment header</dd>
          <dt class="text-[#999] font-medium">Settlement</dt>
          <dd class="font-mono text-[#111]">x402.org/facilitator/settle</dd>
          <dt class="text-[#999] font-medium">Status</dt>
          <dd class="text-[#111]">
            <span class="inline-flex items-center border border-[#111] text-[10px] font-semibold tracking-[0.08em] uppercase px-1.5 py-0.5 leading-none mr-2">Live</span>
            Real 402 response. The recipient address is read from a server-side env var and may be a placeholder in development.
          </dd>
        </dl>
      </div>

      <!-- Introduction -->
      <div class="prose max-w-none mb-10">
        <p>
          This page demonstrates the boundary between the <em>announcement</em> layer and the <em>wire</em> layer of x402. The site advertises that it speaks x402 by declaring a <code>payments.x402</code> block in <code>agents.json</code>; that block names the supported chain and the default pricing, but never the recipient wallet. The recipient appears only when an agent hits a gated resource and receives the 402 response. The demo runs both steps so the boundary is visible.
        </p>
        <p>
          The demo route at <code>/x402</code> is a synthetic gated resource that exists for this page only. A real site gates the resources it actually serves, and the 402 appears on first contact with that resource. <code>agents.json</code> never publishes a "pay here" path because the protocol does not have one; gating is per-resource and the agent learns the recipient at the moment it tries the resource.
        </p>
        <p class="text-xs text-[#777] border-l-2 border-[#e5e5e5] pl-3 italic">
          Per x402 v2, agents.txt v1.0 §8.1, and §5.4: wallet addresses are returned in the 402 response body, never in <code>agents.json</code> or any other discovery file. The demo respects this rule.
        </p>

        <h2>Protocol flow</h2>
        <table>
          <thead>
            <tr><th>Step</th><th>Action</th><th>Result</th></tr>
          </thead>
          <tbody>
            <tr><td class="font-mono">0</td><td>Read declaration from <code>agents.json</code></td><td class="text-[#999]"><code>payments.x402.chains</code>, <code>payments.pricing</code></td></tr>
            <tr><td class="font-mono">1</td><td>Request the gated route (no <code>Payment-Signature</code>)</td><td>402 with one <code>accepts[]</code> entry carrying <code>payTo</code></td></tr>
            <tr><td class="font-mono text-[#ccc]">.</td><td class="text-[#999]">Agent constructs a signed SPL token transfer using the <code>payTo</code> from step 1</td><td class="text-[#999]">off-chain, not executable in a browser</td></tr>
            <tr><td class="font-mono text-[#ccc]">.</td><td class="text-[#999]">Agent retries with <code>Payment-Signature</code>, public facilitator settles, server responds 200</td><td class="text-[#999]">200, <code>X-Payment-Response</code></td></tr>
          </tbody>
        </table>
      </div>

      <!-- Demo runner -->
      <div class="border border-[#e5e5e5]">
        <div class="flex items-center justify-between px-5 py-4 border-b border-[#e5e5e5]">
          <div>
            <p class="text-sm font-semibold text-[#111]">Announcement and wire</p>
            <p class="text-xs text-[#999] mt-0.5">Live requests, no payment executed</p>
          </div>
          <button
            id="run-btn"
            class="flex items-center gap-2 border border-[#111] text-xs font-semibold tracking-[0.06em] uppercase px-4 py-2 hover:bg-[#111] hover:text-white transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
          >
            <span id="run-btn-label">Run</span>
          </button>
        </div>

        <div id="steps" class="divide-y divide-[#e5e5e5]">
          {[
            ['0', 'Announcement', 'GET /agents.json, read payments.x402'],
            ['1', 'Wire',         'GET /x402  (no Payment-Signature) → expect 402 with payTo'],
          ].map(([num, label, hint]) => (
            <div class="step" data-step={num} data-state="idle">
              <div class="flex items-start justify-between gap-4 px-5 py-3">
                <div class="flex items-start gap-3 min-w-0">
                  <span class="step-indicator font-mono text-[10px] text-[#ccc] mt-0.5 shrink-0 w-4">·</span>
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-[#bbb] step-label">{label}</p>
                    <p class="font-mono text-[11px] text-[#ccc] step-hint mt-0.5">{hint}</p>
                  </div>
                </div>
                <span class="step-badge font-mono text-[10px] text-[#ccc] shrink-0 mt-0.5"></span>
              </div>
              <div class="step-body hidden px-5 pb-4">
                <pre class="step-output bg-[#f6f6f6] border border-[#e5e5e5] text-[11px] font-mono text-[#333] p-4 overflow-x-auto whitespace-pre-wrap leading-relaxed m-0"></pre>
              </div>
            </div>
          ))}
        </div>

        <div id="pay-cta" class="hidden px-5 py-4 border-t border-[#e5e5e5] bg-[#fafafa]">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <p class="text-sm font-semibold text-[#111]">Pay 0.01 USDC</p>
              <p class="text-xs text-[#777] mt-1">
                In production, an x402-capable agent would now construct a signed SPL token transfer to <span id="pay-to" class="font-mono text-[#111]">…</span>, base64-encode it into a <code>Payment-Signature</code> header, and retry the request. A browser cannot sign Solana transactions without an extension wallet, so the button below is a no-op call-to-action.
              </p>
            </div>
            <button
              disabled
              title="Demonstration only. Pay flow runs inside an x402-capable agent, not in a browser."
              class="shrink-0 border border-[#111] text-xs font-semibold tracking-[0.06em] uppercase px-4 py-2 opacity-40 cursor-not-allowed"
            >
              Pay
            </button>
          </div>
        </div>

        <div id="result-banner" class="hidden px-5 py-4 border-t border-[#e5e5e5]">
          <p id="result-text" class="text-sm font-medium text-[#111]"></p>
          <p class="text-xs text-[#999] mt-1">The 402 above is the actual response served by this server. To complete a payment, use an x402-capable agent or the <a href="https://github.com/x402-foundation/x402" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">x402 SDK</a>.</p>
        </div>
      </div>

      <!-- Protocol reference -->
      <div class="prose max-w-none mt-12">
        <h2>Protocol reference</h2>

        <h3>The 402 response: <code>accepts[]</code> entry</h3>
        <p>
          Each entry in <code>accepts[]</code> describes one acceptable payment option. For this demo there is a single entry, on Solana, paying USDC. The <code>payTo</code> field is the Associated Token Account (ATA) controlled by the site treasury. The agent uses these fields verbatim when constructing the payment.
        </p>
        <pre><code>{`{
  "x402Version": 2,
  "error": "Payment required",
  "resource": { "url": "https://agentstxt.dev/x402", "..." },
  "accepts": [
    {
      "scheme":  "exact",
      "network": "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
      "amount":  "10000",
      "asset":   "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v",
      "payTo":   "<treasury-ATA>",
      "maxTimeoutSeconds": 60,
      "extra":   { "name": "USDC", "description": "..." }
    }
  ]
}`}</code></pre>

        <h3>The agent retry: <code>Payment-Signature</code> header</h3>
        <p>
          The agent builds a full SPL token transfer transaction including the current blockhash, signs it with its wallet private key, and base64-encodes the serialized bytes. The transaction's validity window is short, typically about 90 seconds. The public facilitator at <code>x402.org/facilitator/settle</code> handles RPC submission and settlement.
        </p>
        <pre><code>{`// Payment-Signature header value (base64-encoded JSON):
{
  "x402Version": 2,
  "scheme":  "exact",
  "network": "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
  "accepted": { /* same shape as accepts[0] above */ },
  "serializedTransaction": "<base64-encoded-signed-tx>"
}`}</code></pre>

        <h3>The settlement response: <code>X-Payment-Response</code></h3>
        <p>
          On success the server returns 200 with the resource and an <code>X-Payment-Response</code> header carrying the on-chain proof. The <code>transaction</code> field is a base58 signature on Solana.
        </p>
        <pre><code>{`{
  "success":     true,
  "transaction": "<solana-tx-signature>",
  "network":     "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
  "payer":       "<payer-address>"
}`}</code></pre>

      </div>

    </div>
  </div>

  <!-- Footer -->
  <footer class="border-t border-[#e5e5e5] mt-4">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="text-xs text-[#999]">
        <span class="font-mono font-semibold text-[#555]">agents.txt</span>
        {' '}Standard v{SPEC_VERSION} ·{' '}
        <a href="/spec" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Spec</a>
        {' '}·{' '}
        <a href="/registry" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Registry</a>
        {' '}·{' '}
        <a href="/demo" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">All demos</a>
      </div>
      <p class="text-xs text-[#bbb]">CC0 (spec) · Apache 2.0 (code). Anyone may implement the standard without restriction.</p>
    </div>
  </footer>
</BaseLayout>

<script>
function getStep(num: string) {
  return document.querySelector<HTMLElement>(`.step[data-step="${num}"]`)!;
}

function setRunning(num: string) {
  const el = getStep(num);
  el.dataset.state = 'running';
  el.querySelector<HTMLElement>('.step-indicator')!.textContent = '▸';
  el.querySelector<HTMLElement>('.step-label')!.classList.replace('text-[#bbb]', 'text-[#111]');
  el.querySelector<HTMLElement>('.step-hint')!.classList.replace('text-[#ccc]', 'text-[#777]');
  el.querySelector<HTMLElement>('.step-badge')!.textContent = '...';
  el.querySelector<HTMLElement>('.step-body')!.classList.remove('hidden');
  el.querySelector<HTMLElement>('.step-output')!.textContent = 'Running...';
}

function setDone(num: string, output: string, badge = '') {
  const el = getStep(num);
  el.dataset.state = 'done';
  el.querySelector<HTMLElement>('.step-indicator')!.textContent = '✓';
  el.querySelector<HTMLElement>('.step-indicator')!.className = 'step-indicator font-mono text-[10px] text-[#111] mt-0.5 shrink-0 w-4';
  el.querySelector<HTMLElement>('.step-badge')!.textContent = badge;
  el.querySelector<HTMLElement>('.step-badge')!.className = 'step-badge font-mono text-[10px] text-[#555] shrink-0 mt-0.5';
  el.querySelector<HTMLElement>('.step-body')!.classList.remove('hidden');
  el.querySelector<HTMLElement>('.step-output')!.textContent = output;
}

function setError(num: string, message: string) {
  const el = getStep(num);
  el.dataset.state = 'error';
  el.querySelector<HTMLElement>('.step-indicator')!.textContent = '✕';
  el.querySelector<HTMLElement>('.step-badge')!.textContent = 'error';
  el.querySelector<HTMLElement>('.step-body')!.classList.remove('hidden');
  el.querySelector<HTMLElement>('.step-output')!.textContent = message;
}

const fmt = (obj: unknown) => JSON.stringify(obj, null, 2);

async function run() {
  const btn = document.getElementById('run-btn')!;
  const label = document.getElementById('run-btn-label')!;
  const banner = document.getElementById('result-banner')!;
  const cta = document.getElementById('pay-cta')!;
  const resultText = document.getElementById('result-text')!;
  const payTo = document.getElementById('pay-to')!;

  btn.setAttribute('disabled', '');
  label.textContent = 'Running...';
  banner.classList.add('hidden');
  cta.classList.add('hidden');
  resultText.className = 'text-sm font-medium text-[#111]';

  document.querySelectorAll<HTMLElement>('.step').forEach(el => {
    el.dataset.state = 'idle';
    el.querySelector<HTMLElement>('.step-indicator')!.textContent = '·';
    el.querySelector<HTMLElement>('.step-indicator')!.className = 'step-indicator font-mono text-[10px] text-[#ccc] mt-0.5 shrink-0 w-4';
    el.querySelector<HTMLElement>('.step-label')!.className = 'text-sm font-medium text-[#bbb] step-label';
    el.querySelector<HTMLElement>('.step-hint')!.className = 'font-mono text-[11px] text-[#ccc] step-hint mt-0.5';
    el.querySelector<HTMLElement>('.step-badge')!.textContent = '';
    el.querySelector<HTMLElement>('.step-badge')!.className = 'step-badge font-mono text-[10px] text-[#ccc] shrink-0 mt-0.5';
    el.querySelector<HTMLElement>('.step-body')!.classList.add('hidden');
    el.querySelector<HTMLElement>('.step-output')!.textContent = '';
  });

  const origin = window.location.origin;

  try {
    // Step 0: announcement layer (agents.json)
    setRunning('0');
    const agentsRes = await fetch(`${origin}/agents.json`);
    const agentsJson = await agentsRes.json() as {
      payments?: {
        x402?:    { chains?: string[]; description?: string };
        required?: boolean;
        pricing?: { amount?: string; currency?: string };
      };
    };
    const payments = agentsJson.payments;
    const chains = payments?.x402?.chains ?? [];
    const pricing = payments?.pricing;
    const x402Declared = chains.length > 0;
    const declarationSummary = x402Declared
      ? [
          `protocol      x402`,
          `chains        ${chains.join(', ')}`,
          `pricing       ${pricing?.amount ?? '?'} ${pricing?.currency ?? ''}`,
          ``,
          `Note: payTo is intentionally absent. The spec forbids wallet addresses`,
          `in agents.json; the recipient is returned in the 402 response only.`,
        ].join('\n')
      : [
          `protocol      not declared`,
          ``,
          `agents.json does not advertise x402 on this deployment.`,
          `The wire step will probe /x402 anyway to show its current behaviour.`,
        ].join('\n');
    setDone('0',
      `GET /agents.json, payments.x402\n\n${declarationSummary}\n\nFull response:\n${fmt(agentsJson)}`,
      x402Declared ? 'declared' : 'not declared',
    );

    // Step 1: wire layer (/x402)
    setRunning('1');
    const paymentRes = await fetch(`${origin}/x402`);
    const paymentBody = await paymentRes.json() as {
      x402Version?: number;
      error?:       string;
      message?:     string;
      accepts?: Array<{
        scheme?:  string;
        network?: string;
        amount?:  string;
        asset?:   string;
        payTo?:   string;
      }>;
    };

    if (paymentRes.status === 503) {
      setDone('1',
        `GET /x402\n\nStatus  503 Service Unavailable\n\n${paymentBody.message ?? ''}\n\nThe demo route requires SOLANA_ADDRESS on the server. Without it, the route returns 503 instead of 402. The announcement step above still ran successfully.`,
        '503 inactive',
      );
      resultText.textContent = 'The /x402 demo route is offline on this deployment (no SOLANA_ADDRESS configured). The announcement layer in step 0 is the spec-mandated declaration; the wire layer is the spec-mandated delivery, currently inactive.';
      banner.classList.remove('hidden');
      return;
    }
    if (paymentRes.status !== 402) {
      throw new Error(`Expected 402 or 503, got ${paymentRes.status}:\n${fmt(paymentBody)}`);
    }

    const accept = paymentBody.accepts?.[0];
    const amountUsdc = accept?.amount
      ? (parseInt(accept.amount, 10) / 1_000_000).toFixed(3)
      : '?';
    const wireSummary = accept
      ? [
          `network       ${accept.network}`,
          `scheme        ${accept.scheme}`,
          `amount        ${amountUsdc} USDC (${accept.amount} atomic)`,
          `asset         ${accept.asset}`,
          `payTo         ${accept.payTo}`,
          ``,
          `Note: payTo appears here, in the 402 response. This is the only`,
          `place the spec and the x402 protocol expose the recipient address.`,
        ].join('\n')
      : '(no accepts[] entries returned)';
    setDone('1',
      `GET /x402  (no Payment-Signature header)\n\nStatus  ${paymentRes.status} Payment Required\n\n${wireSummary}\n\nFull 402 body:\n${fmt(paymentBody)}`,
      `${paymentRes.status} · 1 option`,
    );

    if (accept?.payTo) {
      payTo.textContent = `${accept.payTo.slice(0, 6)}…${accept.payTo.slice(-4)}`;
      payTo.title = accept.payTo;
      cta.classList.remove('hidden');
    }

    resultText.textContent = 'Announcement and wire both ran. agents.json declared the protocol and pricing; the 402 carried the recipient. An x402-capable agent would now sign and submit the SPL transfer.';
    banner.classList.remove('hidden');

  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    const running = document.querySelector<HTMLElement>('.step[data-state="running"]');
    if (running) setError(running.dataset.step!, msg);
    resultText.textContent = 'Flow interrupted. See step above for details.';
    resultText.classList.add('text-[#c00]');
    banner.classList.remove('hidden');
  } finally {
    btn.removeAttribute('disabled');
    label.textContent = 'Run again';
  }
}

document.getElementById('run-btn')!.addEventListener('click', run);
</script>
