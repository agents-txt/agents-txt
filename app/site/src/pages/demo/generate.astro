---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavRight from '../../components/NavRight.astro';
import '../../styles/global.css';
import { SPEC_VERSION } from '../../config';
---

<BaseLayout
  title="File Generator · agents.txt"
  description="Generate agents.txt and agents.json for your site. Select directives, configure options, and copy the output directly into your project. No install required."
  canonicalUrl="https://agents-txt.com/demo/generate"
>
  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-white border-b border-[#e5e5e5]">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="flex items-center no-underline shrink-0" aria-label="agents.txt"><img src="/assets/mark-2.svg" alt="agents.txt" width="26" height="26" class="h-[26px] w-[26px]" /></a>
        <span class="text-[#ccc] select-none">/</span>
        <a href="/demo" class="text-sm text-[#555] hover:text-[#111] transition-colors no-underline whitespace-nowrap">Demos</a>
        <span class="text-[#ccc] select-none">/</span>
        <span class="text-sm text-[#111] whitespace-nowrap">Generate</span>
      </div>
      <NavRight current="demo" />
    </div>
  </header>

  <!-- Page body -->
  <div class="max-w-[1280px] mx-auto px-6 sm:px-10 pt-12 pb-24">

    <!-- Cover -->
    <div class="max-w-[72ch] mb-10 pb-8 border-b border-[#e5e5e5]">
      <h1 class="text-2xl font-bold tracking-tight text-[#111] mb-1">
        File Generator
      </h1>
      <p class="text-sm text-[#777] font-mono mb-6">agents.txt · agents.json · directives · copy-paste</p>
      <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-sm">
        <dt class="text-[#999] font-medium">Output</dt>
        <dd class="font-mono text-[#111]">agents.txt · agents.json</dd>
        <dt class="text-[#999] font-medium">Standard</dt>
        <dd class="text-[#111]">
          <a href="/spec" class="underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all">
            agents.txt v{SPEC_VERSION}
          </a>
        </dd>
        <dt class="text-[#999] font-medium">Method</dt>
        <dd class="text-[#111]">Browser-only · no server calls · no install required</dd>
      </dl>
    </div>

    <!-- Introduction -->
    <div class="prose max-w-none mb-10">
      <p>
        <code>agents.txt</code> is the plain-text announcement layer: minimal directives that tell
        AI agents what capabilities this site supports. <code>agents.json</code> is its structured
        companion, the same information in machine-readable JSON with richer metadata per field.
        Both files live in the public folder of your site so they are served at the root paths
        <code>/agents.txt</code> and <code>/agents.json</code>, where compliant agents discover them automatically.
      </p>
      <p>
        Select the directives you want to declare, fill in the values for your site, then click
        <strong>Generate</strong>. The files are built entirely in your browser. Copy the output
        directly into your project. Optionally, you can use
        <a href="https://github.com/agents-txt/herald" target="_blank" rel="noopener noreferrer">
          HERALD
</a>
        to generate and keep them in sync from <code>agentsjson.config.js</code>.
      </p>

      <h2>Directives</h2>
      <table>
        <thead>
          <tr>
            <th>Directive</th>
            <th>agents.txt</th>
            <th>agents.json</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>Payments</code></td>
            <td><code>Protocols:</code> + optional <code>Payments: required</code></td>
            <td><code>payments.x402.chains</code> · <code>payments.mpp.methods</code> · <code>payments.ap2</code> · <code>payments.pricing</code></td>
          </tr>
          <tr>
            <td><code>Authorization</code></td>
            <td><code>Authorization:</code> + optional <code>Identity: required</code></td>
            <td><code>authorization.protocols</code> · <code>discovery</code> endpoint</td>
          </tr>
          <tr>
            <td><code>MCP</code></td>
            <td><code>MCP: &lt;url&gt;</code></td>
            <td><code>mcp[].url</code> + <code>type: streamable-http</code></td>
          </tr>
          <tr>
            <td><code>Skills</code></td>
            <td><code>Skills: &lt;url&gt;</code></td>
            <td><code>skills[].url</code></td>
          </tr>
          <tr>
            <td><code>UCP</code></td>
            <td><code>UCP: &lt;url&gt;</code></td>
            <td><code>ucp[].url</code></td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- ── Configurator ──────────────────────────────────────────────────────── -->
    <div class="max-w-[72ch] mb-8">
      <div class="border border-[#e5e5e5]">

        <!-- Panel header -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-[#e5e5e5]">
          <p class="text-sm font-semibold text-[#111]">Configure directives</p>
          <button id="generate-btn"
            class="text-xs font-medium px-3 py-1.5 border border-[#111] hover:bg-[#111] hover:text-white transition-colors">
            Generate
          </button>
        </div>

        <!-- Site inputs (always visible) -->
        <div class="px-5 py-5 border-b border-[#e5e5e5]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-4">Site</p>
          <div class="flex flex-col gap-3">
            <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
              <label class="text-xs text-[#555]" for="site-name">Name</label>
              <input id="site-name" type="text" value="My Site"
                class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
            </div>
            <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
              <label class="text-xs text-[#555]" for="site-url">URL</label>
              <input id="site-url" type="text" value="https://example.com"
                class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
            </div>
            <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
              <label class="text-xs text-[#555]" for="site-desc">
                Description
                <span class="text-[#bbb] font-normal">opt.</span>
              </label>
              <input id="site-desc" type="text" placeholder="Short description of your site"
                class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
            </div>
          </div>
        </div>

        <!-- Directive toggles -->
        <div class="divide-y divide-[#e5e5e5]">

          <!-- ── Payments ───────────────────────────────────────────────────── -->
          <div class="px-5 py-4">
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input type="checkbox" id="chk-payments" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
              <span class="text-sm font-medium text-[#111]">Payments</span>
              <span class="font-mono text-[11px] text-[#999]">x402 · MPP</span>
            </label>

            <div id="payments-sub" class="hidden">
              <div class="mt-4 pl-5 flex flex-col gap-5">

                <!-- x402 sub-toggle -->
                <div>
                  <label class="flex items-center gap-3 cursor-pointer select-none mb-3">
                    <input type="checkbox" id="chk-x402" class="w-3.5 h-3.5 accent-[#111] shrink-0" checked />
                    <span class="text-xs font-semibold text-[#111]">x402</span>
                    <span class="font-mono text-[11px] text-[#999]">on-chain · USDC · EVM + Solana</span>
                  </label>
                  <div id="x402-sub" class="pl-5 flex flex-col gap-2.5">
                    <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                      <span class="text-xs text-[#555]">Chains</span>
                      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
                        <label class="flex items-center gap-1.5 cursor-pointer" for="chk-evm">
                          <input type="checkbox" id="chk-evm" class="w-3.5 h-3.5 accent-[#111] shrink-0" checked />
                          <span class="text-xs text-[#111]">EVM <span class="text-[#999] font-mono text-[10px]">(eip155:8453, Base)</span></span>
                        </label>
                        <label class="flex items-center gap-1.5 cursor-pointer" for="chk-solana">
                          <input type="checkbox" id="chk-solana" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
                          <span class="text-xs text-[#111]">Solana <span class="text-[#999] font-mono text-[10px]">(solana:5eykt...vdp, mainnet)</span></span>
                        </label>
                      </div>
                    </div>
                    <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                      <label class="text-xs text-[#555]" for="x402-price">
                        Default price
                        <span class="text-[#bbb] font-normal">opt.</span>
                      </label>
                      <div class="flex gap-2">
                        <input id="x402-price" type="text" placeholder="0.001"
                          class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                        <input id="x402-token" type="text" placeholder="USDC"
                          class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-20 shrink-0" />
                      </div>
                    </div>
                    <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                      <label class="text-xs text-[#555]" for="x402-description">
                        Description
                        <span class="text-[#bbb] font-normal">opt.</span>
                      </label>
                      <input id="x402-description" type="text" placeholder="Access to premium API endpoints"
                        class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                    </div>
                    <p class="text-[11px] text-[#999] leading-relaxed">
                      No wallet address is requested here, by design: per spec §8.1 and §5.4, treasury addresses appear in <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">402</code> responses only, never in <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">agents.txt</code> or <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">agents.json</code>. The form just collects the *capability* declarations: chains under <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">payments.x402.chains</code>, optional <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">pricing</code> and <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">payments.x402.description</code>. Your wallet stays in your server's 402 handler.
                    </p>
                  </div>
                </div>

                <!-- MPP sub-toggle -->
                <div>
                  <label class="flex items-center gap-3 cursor-pointer select-none mb-3">
                    <input type="checkbox" id="chk-mpp" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
                    <span class="text-xs font-semibold text-[#111]">MPP</span>
                    <span class="font-mono text-[11px] text-[#999]">fiat + USDC · session-based · Stripe · Tempo</span>
                  </label>
                  <div id="mpp-sub" class="hidden">
                    <div class="pl-5 flex flex-col gap-2.5">
                      <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                        <span class="text-xs text-[#555]">Methods</span>
                        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
                          <label class="flex items-center gap-1.5 cursor-pointer" for="chk-mpp-tempo">
                            <input type="checkbox" id="chk-mpp-tempo" class="w-3.5 h-3.5 accent-[#111] shrink-0" checked />
                            <span class="text-xs text-[#111]">Tempo <span class="text-[#999] font-mono text-[10px]">(USDC.e stablecoin)</span></span>
                          </label>
                          <label class="flex items-center gap-1.5 cursor-pointer" for="chk-mpp-stripe">
                            <input type="checkbox" id="chk-mpp-stripe" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
                            <span class="text-xs text-[#111]">Stripe <span class="text-[#999] font-mono text-[10px]">(SPT: cards, Solana USDC)</span></span>
                          </label>
                        </div>
                      </div>
                      <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                        <label class="text-xs text-[#555]" for="mpp-price">
                          Default price
                          <span class="text-[#bbb] font-normal">opt.</span>
                        </label>
                        <div class="flex gap-2">
                          <input id="mpp-price" type="text" placeholder="0.001"
                            class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                          <input id="mpp-token" type="text" placeholder="USD"
                            class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-20 shrink-0" />
                        </div>
                      </div>
                      <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                        <label class="text-xs text-[#555]" for="mpp-description">
                          Description
                          <span class="text-[#bbb] font-normal">opt.</span>
                        </label>
                        <input id="mpp-description" type="text" placeholder="Premium content access"
                          class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                      </div>
                      <p class="text-[11px] text-[#999] leading-relaxed">
                        No recipient address is requested here, by design: per spec §8.2 and §5.4, the recipient (Tempo wallet or Stripe Business Network profile) appears inside the <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">WWW-Authenticate: Payment</code> challenge at request time, never in <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">agents.txt</code> or <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">agents.json</code>. Selected methods are surfaced as <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">payments.mpp.methods</code>; optional pricing as <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">payments.pricing</code>; optional description as <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">payments.mpp.description</code>. Your credentials stay in your server's MPP handler.
                      </p>
                    </div>
                  </div>
                </div>

                <!-- AP2 sub-toggle -->
                <div>
                  <label class="flex items-center gap-3 cursor-pointer select-none mb-3">
                    <input type="checkbox" id="chk-ap2" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
                    <span class="text-xs font-semibold text-[#111]">AP2</span>
                    <span class="font-mono text-[11px] text-[#999]">mandate layer · VDC · composes with x402 / MPP / UCP</span>
                  </label>
                  <div id="ap2-sub" class="hidden">
                    <div class="pl-5 flex flex-col gap-2.5">
                      <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                        <span class="text-xs text-[#555]">Presentations</span>
                        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
                          <label class="flex items-center gap-1.5 cursor-pointer" for="chk-ap2-sdjwt">
                            <input type="checkbox" id="chk-ap2-sdjwt" class="w-3.5 h-3.5 accent-[#111] shrink-0" checked />
                            <span class="text-xs text-[#111]">sd-jwt-vc <span class="text-[#999] font-mono text-[10px]">(SD-JWT Verifiable Credential)</span></span>
                          </label>
                        </div>
                      </div>
                      <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                        <label class="text-xs text-[#555]" for="ap2-spec">
                          Spec URL
                          <span class="text-[#bbb] font-normal">opt.</span>
                        </label>
                        <input id="ap2-spec" type="text" placeholder="https://ap2-protocol.org/specification/v0.1"
                          class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                      </div>
                      <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                        <label class="text-xs text-[#555]" for="ap2-description">
                          Description
                          <span class="text-[#bbb] font-normal">opt.</span>
                        </label>
                        <input id="ap2-description" type="text" placeholder="AP2 mandates accepted alongside x402 settlement"
                          class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                      </div>
                      <p class="text-[11px] text-[#999] leading-relaxed">
                        AP2 is a mandate trust layer per spec §8.3. It carries signed <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">CheckoutMandate</code> and <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">PaymentMandate</code> Verifiable Digital Credentials over an existing rail (x402, MPP, or a UCP payment handler), not a rail of its own. The fields here surface in <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">agents.json</code> under <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">payments.ap2</code> for pre-screening; the mandate exchange itself happens during checkout per the AP2 specification.
                      </p>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- ── Authorization ──────────────────────────────────────────────── -->
          <div class="px-5 py-4">
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input type="checkbox" id="chk-auth" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
              <span class="text-sm font-medium text-[#111]">Authorization</span>
              <span class="font-mono text-[11px] text-[#999]">agent-auth · oauth2 · pick one or both</span>
            </label>
            <div id="auth-sub" class="hidden">
              <div class="mt-4 pl-5 flex flex-col gap-5">

                <!-- agent-auth sub-toggle -->
                <div>
                  <label class="flex items-center gap-3 cursor-pointer select-none">
                    <input type="checkbox" id="chk-auth-agent-auth" class="w-3.5 h-3.5 accent-[#111] shrink-0" checked />
                    <span class="text-xs font-semibold text-[#111]">agent-auth</span>
                    <span class="font-mono text-[11px] text-[#999]">Ed25519 · JWT · per-agent identity with capability grants</span>
                  </label>
                  <p class="pl-5 mt-2 text-[11px] text-[#999] leading-relaxed">
                    Discovery at <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">/.well-known/agent-configuration</code>. Each agent holds an Ed25519 keypair, registers under a host, and signs per-request JWTs scoped to specific capabilities.
                  </p>
                </div>

                <!-- oauth2 sub-toggle -->
                <div>
                  <label class="flex items-center gap-3 cursor-pointer select-none">
                    <input type="checkbox" id="chk-auth-oauth2" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
                    <span class="text-xs font-semibold text-[#111]">oauth2</span>
                    <span class="font-mono text-[11px] text-[#999]">RFC 6749 · client-credentials · scope-based</span>
                  </label>
                  <p class="pl-5 mt-2 text-[11px] text-[#999] leading-relaxed">
                    Discovery at <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">/.well-known/oauth-authorization-server</code> (RFC 8414) and <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">/.well-known/openid-configuration</code> (OIDC alias). Per-client credentials authenticate, scopes gate the resource.
                  </p>
                </div>

                <!-- Identity: required policy hint -->
                <label class="flex items-center gap-3 cursor-pointer select-none">
                  <input type="checkbox" id="chk-identity" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
                  <span class="text-xs text-[#555]">
                    <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">Identity: required</code>:
                    agents must authenticate before any interaction, not just capability execution
                  </span>
                </label>
              </div>
            </div>
          </div>

          <!-- ── MCP ────────────────────────────────────────────────────────── -->
          <div class="px-5 py-4">
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input type="checkbox" id="chk-mcp" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
              <span class="text-sm font-medium text-[#111]">MCP</span>
              <span class="font-mono text-[11px] text-[#999]">Model Context Protocol · Streamable HTTP</span>
            </label>
            <div id="mcp-sub" class="hidden">
              <div class="mt-4 pl-5 flex flex-col gap-2.5">
                <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                  <label class="text-xs text-[#555]" for="mcp-url">Endpoint URL</label>
                  <input id="mcp-url" type="text" placeholder="https://example.com/mcp"
                    class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                </div>
                <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                  <label class="text-xs text-[#555]" for="mcp-desc">
                    Description
                    <span class="text-[#bbb] font-normal">opt.</span>
                  </label>
                  <input id="mcp-desc" type="text" placeholder="What this MCP server exposes"
                    class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                </div>
                <p class="text-[11px] text-[#999] leading-relaxed">
                  Must support both POST and GET (MCP spec 2025-03-26+). Transport is always <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">streamable-http</code>. Description appears in <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">agents.json</code> only.
                </p>
              </div>
            </div>
          </div>

          <!-- ── UCP ────────────────────────────────────────────────────────── -->
          <div class="px-5 py-4">
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input type="checkbox" id="chk-ucp" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
              <span class="text-sm font-medium text-[#111]">UCP</span>
              <span class="font-mono text-[11px] text-[#999]">Universal Commerce Protocol · profile discovery</span>
            </label>
            <div id="ucp-sub" class="hidden">
              <div class="mt-4 pl-5 flex flex-col gap-2.5">
                <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                  <label class="text-xs text-[#555]" for="ucp-url">Profile URL</label>
                  <input id="ucp-url" type="text" placeholder="https://example.com/.well-known/ucp"
                    class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                </div>
                <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                  <label class="text-xs text-[#555]" for="ucp-desc">
                    Description
                    <span class="text-[#bbb] font-normal">opt.</span>
                  </label>
                  <input id="ucp-desc" type="text" placeholder="What this UCP profile covers (e.g. B2C shopping)"
                    class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                </div>
                <p class="text-[11px] text-[#999] leading-relaxed">
                  UCP is an A2P protocol for commerce capabilities (checkout, cart, catalog, order, fulfillment, AP2 mandates). The well-known path <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">/.well-known/ucp</code> covers single-profile sites; this directive (spec §10) handles multi-profile sites and non-canonical paths. Description appears in <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">agents.json</code> only.
                </p>
              </div>
            </div>
          </div>

          <!-- ── Skills ─────────────────────────────────────────────────────── -->
          <div class="px-5 py-4">
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input type="checkbox" id="chk-skills" class="w-3.5 h-3.5 accent-[#111] shrink-0" />
              <span class="text-sm font-medium text-[#111]">Skills</span>
              <span class="font-mono text-[11px] text-[#999]">agentskills.io · skill packages</span>
            </label>
            <div id="skills-sub" class="hidden">
              <div class="mt-4 pl-5 flex flex-col gap-2.5">
                <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                  <label class="text-xs text-[#555]" for="skills-url">Package URL</label>
                  <input id="skills-url" type="text" placeholder="https://example.com/skills/my-skill/SKILL.md"
                    class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                </div>
                <div class="grid grid-cols-[7rem_1fr] items-center gap-3">
                  <label class="text-xs text-[#555]" for="skills-desc">
                    Description
                    <span class="text-[#bbb] font-normal">opt.</span>
                  </label>
                  <input id="skills-desc" type="text" placeholder="What this skill package teaches agents"
                    class="font-mono text-xs px-2.5 py-1.5 border border-[#e5e5e5] focus:border-[#111] outline-none bg-white transition-colors w-full" />
                </div>
                <p class="text-[11px] text-[#999] leading-relaxed">
                  Service-consumption skill packages teach agents how to use your API. Description appears in <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">agents.json</code> only. May be gated behind payment; agents handle <code class="font-mono bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5 text-[10px]">402</code> normally.
                </p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- ── Output ────────────────────────────────────────────────────────────── -->
    <div id="output-section" class="hidden">

      <div class="pb-6 mb-6 border-b border-[#e5e5e5]">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">Generated output</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- agents.txt -->
        <div class="border border-[#e5e5e5]">
          <div class="flex items-center justify-between px-5 py-3 border-b border-[#e5e5e5]">
            <p class="font-mono text-xs font-semibold text-[#111]">agents.txt</p>
            <button id="copy-txt"
              class="text-[11px] font-medium text-[#555] hover:text-[#111] transition-colors border border-[#e5e5e5] hover:border-[#111] px-2.5 py-1">
              Copy
            </button>
          </div>
          <pre id="out-txt" class="px-5 py-4 font-mono text-xs text-[#111] leading-relaxed overflow-x-auto bg-[#fafafa] whitespace-pre min-h-[8rem]"></pre>
        </div>

        <!-- agents.json -->
        <div class="border border-[#e5e5e5]">
          <div class="flex items-center justify-between px-5 py-3 border-b border-[#e5e5e5]">
            <p class="font-mono text-xs font-semibold text-[#111]">agents.json</p>
            <button id="copy-json"
              class="text-[11px] font-medium text-[#555] hover:text-[#111] transition-colors border border-[#e5e5e5] hover:border-[#111] px-2.5 py-1">
              Copy
            </button>
          </div>
          <pre id="out-json" class="px-5 py-4 font-mono text-xs text-[#111] leading-relaxed overflow-x-auto bg-[#fafafa] whitespace-pre min-h-[8rem]"></pre>
        </div>

      </div>

      <p class="text-xs text-[#999] mt-6 leading-relaxed">
        Place <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.txt</code> and <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.json</code> in the <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">/public</code> folder of your site so they are automatically served. For ongoing sync you can optionally use the <a href="https://github.com/agents-txt/herald" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">HERALD</a>, where <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">herald emit</code> regenerates both from <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agentsjson.config.js</code> on demand.
      </p>
    </div>

  </div>

  <!-- Footer -->
  <footer class="border-t border-[#e5e5e5] mt-4">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="text-xs text-[#999]">
        <img src="/assets/wordmark.svg" alt="agents.txt" class="inline-block h-[16px] w-auto align-middle" />
        {' '}
        <a href="/spec" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Spec</a>
        {' '}·{' '}
        <a href="/registry" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Registry</a>
      </div>
      <p class="text-xs text-[#bbb]">CC0 (spec) · Apache 2.0 (code).</p>
    </div>
  </footer>

  <script>
    // ── Directive panel toggles ────────────────────────────────────────────────
    function wireToggle(checkboxId: string, panelId: string): void {
      const chk = document.getElementById(checkboxId) as HTMLInputElement | null
      const panel = document.getElementById(panelId)
      if (!chk || !panel) return
      chk.addEventListener('change', () => {
        panel.classList.toggle('hidden', !chk.checked)
      })
    }

    wireToggle('chk-payments', 'payments-sub')
    wireToggle('chk-x402',    'x402-sub')
    wireToggle('chk-mpp',     'mpp-sub')
    wireToggle('chk-ap2',     'ap2-sub')
    wireToggle('chk-auth',    'auth-sub')
    wireToggle('chk-mcp',     'mcp-sub')
    wireToggle('chk-skills',  'skills-sub')
    wireToggle('chk-ucp',     'ucp-sub')

    // ── Generator state ────────────────────────────────────────────────────────
    interface GenConfig {
      name:             string
      url:              string
      description:      string
      payments:         boolean
      x402:             boolean
      evmChain:         boolean
      solanaChain:      boolean
      x402Price:        string
      x402Token:        string
      x402Description:  string
      mpp:              boolean
      mppTempo:         boolean
      mppStripe:        boolean
      mppPrice:         string
      mppToken:         string
      mppDescription:   string
      ap2:              boolean
      ap2SdJwt:         boolean
      ap2Spec:          string
      ap2Description:   string
      authorization:    boolean
      authAgentAuth:    boolean
      authOauth2:       boolean
      identityRequired: boolean
      mcp:              boolean
      mcpUrl:           string
      mcpDescription:   string
      skills:           boolean
      skillsUrl:        string
      skillsDescription: string
      ucp:              boolean
      ucpUrl:           string
      ucpDescription:   string
    }

    // ── Input sanitization ─────────────────────────────────────────────────
    // Every value the user types goes through one of three normalizers below
    // before it lands in the generated agents.txt / agents.json. The output is
    // pure text (and then JSON via JSON.stringify), but agents.txt is a
    // line-oriented format: a stray newline or `# ` injected into a field
    // would corrupt the file in a way that survives copy-paste. The token,
    // price, and URL normalizers each strip out the wire-syntax characters
    // that would matter on their respective field.
    //
    // No backend submission happens here (everything is browser-side), so
    // this is XSS-as-template-injection prevention, not server-side input
    // hardening. The output `<pre>` blocks set textContent (not innerHTML),
    // which already prevents script execution; these normalizers stop the
    // user from accidentally pasting a multi-line value that breaks the file
    // format the moment they copy it into their site's /public folder.
    const MAX_TEXT_LEN  = 200
    const MAX_DESC_LEN  = 400
    const MAX_URL_LEN   = 2048

    // Strip ASCII control chars (incl. newlines/tabs) and zero-width
    // characters that would invisibly survive a paste into a text editor.
    // Collapse internal whitespace to a single space; cap at maxLen.
    function sanitizeText(raw: string, maxLen = MAX_TEXT_LEN): string {
      // Strip ASCII C0 + DEL controls, zero-width chars, BiDi marks, BOM.
      // Built from \uXXXX escapes so the source stays plain ASCII and the
      // Astro parser does not see literal control bytes.
      // eslint-disable-next-line no-control-regex
      const FORBIDDEN = /[\u0000-\u001F\u007F\u200B-\u200F\u2028\u2029\uFEFF]/g
      const stripped = raw
        .replace(FORBIDDEN, "")
        .replace(/\s+/g, " ")
        .trim()
      return stripped.length > maxLen ? stripped.slice(0, maxLen) : stripped
    }

    // URLs must be syntactically valid and HTTPS (spec §4.1 requires HTTPS
    // for every URL-carrying directive: MCP, Skills, UCP). Reject anything
    // else by returning empty string, which causes the generator to fall
    // back to its placeholder. The constructor handles userinfo, fragments,
    // bidirectional control chars, etc. natively.
    function sanitizeUrl(raw: string): string {
      const trimmed = sanitizeText(raw, MAX_URL_LEN)
      if (!trimmed) return ''
      try {
        const u = new URL(trimmed)
        if (u.protocol !== 'https:') return ''
        return u.toString()
      } catch {
        return ''
      }
    }

    // Numeric price strings: digits and a single dot, no scientific notation
    // or sign. agents.json carries the amount as a string per spec §5.3.
    function sanitizePrice(raw: string): string {
      const trimmed = sanitizeText(raw, 24)
      if (!/^\d+(\.\d+)?$/.test(trimmed)) return ''
      return trimmed
    }

    // Currency / token tickers: uppercase ASCII letters, 1-8 chars.
    function sanitizeToken(raw: string): string {
      const upper = sanitizeText(raw, 8).toUpperCase()
      return /^[A-Z]{1,8}$/.test(upper) ? upper : ''
    }

    function readConfig(): GenConfig {
      const v = (id: string): string =>
        ((document.getElementById(id) as HTMLInputElement | null)?.value ?? '').trim()
      const c = (id: string): boolean =>
        !!(document.getElementById(id) as HTMLInputElement | null)?.checked
      return {
        name:              sanitizeText(v('site-name')) || 'My Site',
        url:               sanitizeUrl(v('site-url'))  || 'https://example.com',
        description:       sanitizeText(v('site-desc'), MAX_DESC_LEN),
        payments:          c('chk-payments'),
        x402:              c('chk-x402'),
        evmChain:          c('chk-evm'),
        solanaChain:       c('chk-solana'),
        x402Price:         sanitizePrice(v('x402-price')),
        x402Token:         sanitizeToken(v('x402-token')),
        x402Description:   sanitizeText(v('x402-description'), MAX_DESC_LEN),
        mpp:               c('chk-mpp'),
        mppTempo:          c('chk-mpp-tempo'),
        mppStripe:         c('chk-mpp-stripe'),
        mppPrice:          sanitizePrice(v('mpp-price')),
        mppToken:          sanitizeToken(v('mpp-token')),
        mppDescription:    sanitizeText(v('mpp-description'), MAX_DESC_LEN),
        ap2:               c('chk-ap2'),
        ap2SdJwt:          c('chk-ap2-sdjwt'),
        ap2Spec:           sanitizeUrl(v('ap2-spec')),
        ap2Description:    sanitizeText(v('ap2-description'), MAX_DESC_LEN),
        authorization:     c('chk-auth'),
        authAgentAuth:     c('chk-auth-agent-auth'),
        authOauth2:        c('chk-auth-oauth2'),
        identityRequired:  c('chk-identity'),
        mcp:               c('chk-mcp'),
        mcpUrl:            sanitizeUrl(v('mcp-url')),
        mcpDescription:    sanitizeText(v('mcp-desc'), MAX_DESC_LEN),
        skills:            c('chk-skills'),
        skillsUrl:         sanitizeUrl(v('skills-url')),
        skillsDescription: sanitizeText(v('skills-desc'), MAX_DESC_LEN),
        ucp:               c('chk-ucp'),
        ucpUrl:            sanitizeUrl(v('ucp-url')),
        ucpDescription:    sanitizeText(v('ucp-desc'), MAX_DESC_LEN),
      }
    }

    // ── agents.txt generator (mirrors @herald/core/src/agents-txt.ts) ────────
    function buildAgentsTxt(c: GenConfig): string {
      const base = c.url.replace(/\/$/, '')
      const lines: string[] = [
        '# agents.txt',
        '# Standard: https://agents-txt.com',
        `# JSON: ${base}/agents.json`,
      ]

      if (c.payments) {
        const protocols: string[] = []
        if (c.x402 && (c.evmChain || c.solanaChain)) protocols.push('x402')
        if (c.mpp && (c.mppTempo || c.mppStripe)) protocols.push('mpp')
        if (c.ap2) protocols.push('ap2')
        if (protocols.length > 0) {
          lines.push('', `Protocols: ${protocols.join(', ')}`)
        }
      }

      if (c.authorization) {
        const authProtocols: string[] = []
        if (c.authAgentAuth) authProtocols.push('agent-auth')
        if (c.authOauth2)    authProtocols.push('oauth2')
        if (authProtocols.length > 0) {
          lines.push('', `Authorization: ${authProtocols.join(', ')}`)
          if (c.identityRequired) lines.push('Identity: required')
        }
      }

      if (c.mcp) {
        lines.push('', `MCP: ${c.mcpUrl || 'https://example.com/mcp'}`)
      }

      if (c.skills) {
        lines.push('', `Skills: ${c.skillsUrl || 'https://example.com/skills/my-skill/SKILL.md'}`)
      }

      if (c.ucp) {
        lines.push('', `UCP: ${c.ucpUrl || 'https://example.com/.well-known/ucp'}`)
      }

      return lines.join('\n') + '\n'
    }

    // ── agents.json generator (mirrors @herald/core/src/agents-json.ts) ──────
    const SOLANA_MAINNET_CHAIN = 'solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp'

    function buildAgentsJson(c: GenConfig): string {
      const obj: Record<string, unknown> = {
        version: '1.0',
        standard: 'https://agents-txt.com',
        site: {
          name: c.name,
          url: c.url,
          ...(c.description ? { description: c.description } : {}),
        },
      }

      if (c.payments) {
        const p: Record<string, unknown> = {}
        const x402Active = c.x402 && (c.evmChain || c.solanaChain)

        if (x402Active) {
          const chains: string[] = []
          if (c.evmChain)    chains.push('eip155:8453')
          if (c.solanaChain) chains.push(SOLANA_MAINNET_CHAIN)
          p.x402 = {
            chains,
            ...(c.x402Description ? { description: c.x402Description } : {}),
          }
        }

        const mppActive = c.mpp && (c.mppTempo || c.mppStripe)
        if (mppActive) {
          const methods: string[] = []
          if (c.mppTempo)  methods.push('tempo')
          if (c.mppStripe) methods.push('stripe')
          p.mpp = {
            methods,
            ...(c.mppDescription ? { description: c.mppDescription } : {}),
          }
        }

        if (c.ap2) {
          const ap2: Record<string, unknown> = {}
          if (c.ap2SdJwt) ap2.presentations = ['sd-jwt-vc']
          if (c.ap2Spec) ap2.spec = c.ap2Spec
          if (c.ap2Description) ap2.description = c.ap2Description
          p.ap2 = ap2
        }

        const hasProtocolBlock = 'x402' in p || 'mpp' in p || 'ap2' in p
        if (hasProtocolBlock) {
          // Pricing reads from x402 first, then mpp as fallback. Belongs at
          // the payments level (not inside a per-protocol block) per spec §5.3.
          const priceAmount = (x402Active && c.x402Price) ? c.x402Price
            : (mppActive && c.mppPrice) ? c.mppPrice
            : ''
          const priceToken  = (x402Active && c.x402Price) ? (c.x402Token || 'USDC')
            : (mppActive && c.mppPrice) ? (c.mppToken || 'USD')
            : ''
          if (priceAmount) {
            p.pricing = {
              amount: priceAmount,
              currency: priceToken,
            }
          }

          obj.payments = p
        }
      }

      if (c.authorization) {
        const authProtocols: string[] = []
        if (c.authAgentAuth) authProtocols.push('agent-auth')
        if (c.authOauth2)    authProtocols.push('oauth2')
        if (authProtocols.length > 0) {
          const auth: Record<string, unknown> = {
            protocols: authProtocols,
            // The `discovery` field announces the non-standard path. agent-auth
            // lives at /.well-known/agent-configuration; OAuth uses RFC-standard
            // /.well-known/oauth-authorization-server which clients fetch by
            // convention. When agent-auth is selected the agent-auth path is the
            // load-bearing announcement; when only oauth2 is selected the OAuth
            // path replaces it.
            discovery: c.authAgentAuth
              ? '/.well-known/agent-configuration'
              : '/.well-known/oauth-authorization-server',
          }
          if (c.identityRequired) auth.identity = 'required'
          obj.authorization = auth
        }
      }

      if (c.mcp) {
        obj.mcp = [{
          url: c.mcpUrl || 'https://example.com/mcp',
          type: 'streamable-http',
          ...(c.mcpDescription ? { description: c.mcpDescription } : {}),
        }]
      }

      if (c.ucp) {
        obj.ucp = [{
          url: c.ucpUrl || 'https://example.com/.well-known/ucp',
          ...(c.ucpDescription ? { description: c.ucpDescription } : {}),
        }]
      }

      if (c.skills) {
        obj.skills = [{
          url: c.skillsUrl || 'https://example.com/skills/my-skill/SKILL.md',
          ...(c.skillsDescription ? { description: c.skillsDescription } : {}),
        }]
      }

      return JSON.stringify(obj, null, 2) + '\n'
    }

    // ── Generate on click ──────────────────────────────────────────────────────
    const generateBtn = document.getElementById('generate-btn')!
    const outputSection = document.getElementById('output-section')!
    const outTxt = document.getElementById('out-txt')!
    const outJson = document.getElementById('out-json')!

    generateBtn.addEventListener('click', () => {
      const cfg = readConfig()
      outTxt.textContent  = buildAgentsTxt(cfg)
      outJson.textContent = buildAgentsJson(cfg)

      if (outputSection.classList.contains('hidden')) {
        outputSection.classList.remove('hidden')
        outputSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
      }
    })

    // ── Copy buttons ───────────────────────────────────────────────────────────
    function wireCopy(btnId: string, sourceId: string): void {
      const btn = document.getElementById(btnId)
      const src = document.getElementById(sourceId)
      if (!btn || !src) return
      btn.addEventListener('click', async () => {
        const text = src.textContent ?? ''
        try {
          await navigator.clipboard.writeText(text)
          btn.textContent = 'Copied'
          setTimeout(() => { btn.textContent = 'Copy' }, 1500)
        } catch {
          btn.textContent = 'Error'
          setTimeout(() => { btn.textContent = 'Copy' }, 1500)
        }
      })
    }

    wireCopy('copy-txt',  'out-txt')
    wireCopy('copy-json', 'out-json')
  </script>

</BaseLayout>
