---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavRight from '../components/NavRight.astro';
import Toc from '../components/Toc.astro';
import '../styles/global.css';
import { getCollection, render } from 'astro:content';
import { SPEC_VERSION } from '../config';

const entries = await getCollection('spec');
const entry = entries[0];
const { Content, headings } = await render(entry);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Parse the leading **Label:** value lines out of the markdown body so the
// page header dl stays in sync with the spec source instead of being
// hardcoded. Stops at the first blank line after the contiguous metadata
// block so unrelated bold-prefixed paragraphs further down are not picked up.
type SpecMetaItem = { label: string; value: string };
const specMeta: SpecMetaItem[] = [];
{
  let inBlock = false;
  for (const rawLine of entry.body.split('\n')) {
    const line = rawLine.trim();
    const m = line.match(/^\*\*([^:*]+):\*\*\s*(.+?)$/);
    if (m) {
      inBlock = true;
      specMeta.push({ label: m[1].trim(), value: m[2].trim() });
    } else if (inBlock && line === '') {
      break;
    }
  }
}
const stripScheme = (url: string) => url.replace(/^https?:\/\//, '');

// Parse [text](url) markdown links out of a metadata value. Returns a list of
// {text, href?} parts; plain text parts have no href.
type InlinePart = { text: string; href?: string };
const parseInline = (value: string): InlinePart[] => {
  const parts: InlinePart[] = [];
  const re = /\[([^\]]+)\]\(([^)]+)\)/g;
  let last = 0;
  let m: RegExpExecArray | null;
  while ((m = re.exec(value)) !== null) {
    if (m.index > last) parts.push({ text: value.slice(last, m.index) });
    parts.push({ text: m[1], href: m[2] });
    last = m.index + m[0].length;
  }
  if (last < value.length) parts.push({ text: value.slice(last) });
  return parts.length ? parts : [{ text: value }];
};
---

<BaseLayout
  title="Specification · agents.txt Standard"
  description="The full text of the agents.txt v1.0 specification. An open set of capability blocks (currently Payments, Authorization, MCP, Skills, A2A, UCP), the agents.json companion schema, §4.5 serving requirements, and the reference deployment's header configuration."
  canonicalUrl="https://agents-txt.com/spec"
>
  <!-- Top nav -->
  <header class="sticky top-0 z-50 bg-white border-b border-[#e5e5e5]">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="flex items-center no-underline shrink-0" aria-label="agents.txt"><img src="/assets/mark-2.svg" alt="agents.txt" width="26" height="26" class="h-[26px] w-[26px]" /></a>
        <span class="hidden sm:inline text-[#ccc] select-none">/</span>
        <span class="hidden sm:inline text-sm text-[#555] whitespace-nowrap">Standard</span>
        <span
          class="hidden sm:inline-flex items-center border border-[#111] text-[10px] font-semibold tracking-[0.08em] uppercase px-1.5 py-0.5 leading-none"
        >
          Draft
        </span>
      </div>
      <NavRight current="spec">
        <!-- Hamburger — mobile only -->
        <button
          id="toc-toggle"
          class="lg:hidden flex flex-col justify-center items-center w-8 h-8 gap-[5px] text-[#555] hover:text-[#111] transition-colors"
          aria-label="Toggle table of contents"
          aria-expanded="false"
          aria-controls="mobile-toc"
        >
          <span class="hamburger-bar block w-5 h-px bg-current transition-all duration-200"></span>
          <span class="hamburger-bar block w-5 h-px bg-current transition-all duration-200"></span>
          <span class="hamburger-bar block w-5 h-px bg-current transition-all duration-200"></span>
        </button>
      </NavRight>
    </div>
  </header>

  <!-- Mobile TOC panel — hidden by default, toggled by hamburger -->
  <div
    id="mobile-toc"
    class="lg:hidden hidden sticky top-14 z-40 bg-white border-b border-[#e5e5e5] max-h-[60vh] overflow-y-auto"
  >
    <nav class="max-w-[1280px] mx-auto px-6 sm:px-10 py-4">
      <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-[#999] mb-3">
        On this page
      </p>
      {tocHeadings.map((h) => (
        <a
          href={`#${h.slug}`}
          data-mobile-toc-link
          class:list={['toc-link', h.depth === 3 && 'toc-h3']}
        >
          {h.text}
        </a>
      ))}
    </nav>
  </div>

  <!-- Page body -->
  <div class="max-w-[1280px] mx-auto px-6 sm:px-10 pt-12 pb-24">
    <div class="lg:flex lg:gap-16 xl:gap-24">

      <!-- Spec content -->
      <main class="min-w-0 flex-1">

        <!-- Spec cover / metadata -->
        <div class="mb-10 pb-8 border-b border-[#e5e5e5]">
          <h1 class="text-2xl font-bold tracking-tight text-[#111] mb-1">
            agents.txt Standard
          </h1>
          <p class="text-sm text-[#777] font-mono mb-6">v{SPEC_VERSION}</p>
          <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-sm">
            {specMeta.map((item) => (
              <>
                <dt class="text-[#999] font-medium">{item.label}</dt>
                {item.label === 'Status' ? (
                  <dd class="text-[#111]">
                    <span class="inline-flex items-center border border-[#111] text-[10px] font-semibold tracking-[0.08em] uppercase px-1.5 py-0.5 leading-none mr-2">
                      {item.value}
                    </span>
                    This document is a work in progress and subject to change.
                  </dd>
                ) : item.label === 'Version' ? (
                  <dd class="font-mono text-[#111]">{item.value}</dd>
                ) : item.label === 'Repository' ? (
                  (() => {
                    const parts = parseInline(item.value);
                    const linked = parts.find((p) => p.href);
                    const href = linked?.href ?? item.value;
                    const text = linked ? linked.text : stripScheme(item.value);
                    return (
                      <dd>
                        <a
                          href={href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-mono text-[#111] underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all"
                        >
                          {text}
                        </a>
                      </dd>
                    );
                  })()
                ) : item.label === 'Contact' && item.value.includes('@') && !item.value.startsWith('http') ? (
                  <dd>
                    <a
                      href={`mailto:${item.value}`}
                      class="font-mono text-[#111] underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all"
                    >
                      {item.value}
                    </a>
                  </dd>
                ) : item.label === 'Published' ? (
                  <dd class="font-mono text-[#111]">{item.value}</dd>
                ) : (
                  <dd class="text-[#111]">
                    {parseInline(item.value).map((part) => (
                      part.href ? (
                        <a
                          href={part.href}
                          target={part.href.startsWith('http') ? '_blank' : undefined}
                          rel={part.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                          class="underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all"
                        >
                          {part.text}
                        </a>
                      ) : (
                        <span>{part.text}</span>
                      )
                    ))}
                  </dd>
                )}
              </>
            ))}
          </dl>
        </div>

        <!-- Rendered spec -->
        <article class="prose max-w-none spec-content">
          <Content />
        </article>
      </main>

      <!-- Sticky TOC (desktop) -->
      <aside class="hidden lg:block w-60 xl:w-64 shrink-0">
        <div class="sticky top-[4.5rem] max-h-[calc(100vh-5.5rem)] overflow-y-auto pb-8 scrollbar-thin">
          <Toc headings={headings} />
        </div>
      </aside>

    </div>
  </div>

  <!-- Footer -->
  <footer class="border-t border-[#e5e5e5] mt-4">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="text-xs text-[#999]">
        <img src="/assets/wordmark.svg" alt="agents.txt" class="inline-block h-[16px] w-auto align-middle" />
        {' '}
        <a
          href="https://github.com/agents-txt/agents-txt/blob/main/app/site/src/content/spec/AGENTS-TXT-STANDARD.md"
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all"
        >
          View source
        </a>
      </div>
      <p class="text-xs text-[#bbb]">CC0 (spec) · Apache 2.0 (code).</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Hide the H1 from rendered markdown — shown in cover section above */
  .spec-content :global(h1:first-child) { display: none; }
  .spec-content :global(h1:first-child + p) { display: none; }
  .spec-content :global(h1:first-child + p + hr) { display: none; }

  /* Scrollbar */
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: #e5e5e5 transparent;
  }

  /* Hamburger → X animation when open */
  #toc-toggle.is-open .hamburger-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #toc-toggle.is-open .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  #toc-toggle.is-open .hamburger-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById('toc-toggle');
  const panel = document.getElementById('mobile-toc');

  toggle?.addEventListener('click', () => {
    const isOpen = !panel?.classList.contains('hidden');
    panel?.classList.toggle('hidden', isOpen);
    toggle.classList.toggle('is-open', !isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close panel when a TOC link is tapped
  document.querySelectorAll('[data-mobile-toc-link]').forEach((link) => {
    link.addEventListener('click', () => {
      panel?.classList.add('hidden');
      toggle?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
