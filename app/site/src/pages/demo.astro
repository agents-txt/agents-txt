---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import { SPEC_VERSION } from '../config';
---

<BaseLayout
  title="Demos · agents.txt"
  description="Working protocol demonstrations for the agents.txt standard. Agent Auth, MCP, Skills, A2A, UCP, and payment protocols running live against this server."
  canonicalUrl="https://agentstxt.dev/demo"
>
  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-white border-b border-[#e5e5e5]">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="font-mono text-sm font-semibold tracking-tight text-[#111] no-underline whitespace-nowrap">
          agents.txt
        </a>
        <span class="hidden sm:inline text-[#ccc] select-none">/</span>
        <span class="hidden sm:inline text-sm text-[#555] whitespace-nowrap">Demos</span>
      </div>
      <div class="flex items-center gap-x-3 sm:gap-x-5 shrink-0">
        <a href="/spec" class="text-xs text-[#555] hover:text-[#111] transition-colors no-underline">Spec</a>
        <a href="/agents.txt" class="font-mono text-xs text-[#555] hover:text-[#111] transition-colors no-underline">agents.txt</a>
        <a href="/agents.json" class="font-mono text-xs text-[#555] hover:text-[#111] transition-colors no-underline">agents.json</a>
        <a href="/demo" class="text-xs font-medium text-[#111] no-underline border-b border-[#111]">Demo</a>
        <span class="hidden sm:block text-[#ddd] select-none">|</span>
        <a href="https://github.com/agentstxt/agents.txt" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub"
          class="flex text-xs text-[#555] hover:text-[#111] transition-colors no-underline items-center gap-1">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      </div>
    </div>
  </header>

  <!-- Page body -->
  <div class="max-w-[1280px] mx-auto px-6 sm:px-10 pt-12 pb-24">
    <div>

      <!-- Cover -->
      <div class="mb-10 pb-8 border-b border-[#e5e5e5]">
        <h1 class="text-2xl font-bold tracking-tight text-[#111] mb-1">
          Protocol Demonstrations
        </h1>
        <p class="text-sm text-[#777] font-mono mb-4">Live · executing against this server in real time</p>
        <p class="text-sm text-[#555] leading-relaxed">
          Each demo runs a complete protocol flow in your browser against the live production endpoints of this server. No installation, no API keys, no recorded responses. Everything executes on demand.
        </p>
      </div>

      <!-- Demo listings -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 auto-rows-fr">

        <!-- Generator -->
        <a href="/demo/generate" class="block group no-underline h-full">
          <div class="border border-[#e5e5e5] group-hover:border-[#111] transition-colors h-full flex flex-col">
            <div class="px-6 py-5 border-b border-[#e5e5e5] flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111]">File Generator</p>
                  <p class="font-mono text-[11px] text-[#999] mt-1">agents.txt · agents.json · directives · copy-paste</p>
                </div>
                <span class="font-mono text-xs text-[#999] group-hover:text-[#111] transition-colors shrink-0 mt-0.5">
                  Generate →
                </span>
              </div>
              <p class="text-sm text-[#555] mt-3 leading-relaxed">
                Configure which directives to include and generate both files instantly in your browser. Select payment protocols, authorization, MCP endpoints, and skill URLs, then copy the output directly into your project. No installation, no API keys, no server calls.
              </p>
            </div>
            <div class="px-6 py-4 bg-[#fafafa]">
              <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-3">Steps covered</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-1.5 gap-x-8">
                {[
                  ['0', 'Site metadata (name, URL, description)'],
                  ['1', 'Directive selection (Payments, Auth, MCP, Skills)'],
                  ['2', 'agents.txt: plain-text declaration'],
                  ['3', 'agents.json: structured companion'],
                ].map(([num, label]) => (
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-[10px] text-[#bbb] shrink-0 w-4">{num}</span>
                    <span class="text-xs text-[#555]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </a>

        <!-- Discovery & Content Layers demo -->
        <a href="/demo/llms" class="block group no-underline h-full">
          <div class="border border-[#e5e5e5] group-hover:border-[#111] transition-colors h-full flex flex-col">
            <div class="px-6 py-5 border-b border-[#e5e5e5] flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111]">Discovery & Content Layers</p>
                  <p class="font-mono text-[11px] text-[#999] mt-1">Layers 1, 2, 3 · robots.txt · sitemap.xml · llms.txt · §4.5 headers</p>
                </div>
                <span class="font-mono text-xs text-[#999] group-hover:text-[#111] transition-colors shrink-0 mt-0.5">
                  Run demo →
                </span>
              </div>
              <p class="text-sm text-[#555] mt-3 leading-relaxed">
                Fetches every discovery and content file served by this site and shows what each layer carries. <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">/robots.txt</code> for crawler policy (Layer 1, RFC 9309), <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">/sitemap.xml</code> for the page inventory (Layer 2), <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">/llms.txt</code> and <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">/llms-full.txt</code> for the curated reading list (Layer 3), plus a §4.5 headers check that confirms <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">/agents.txt</code> and <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">/agents.json</code> serve with the right Content-Type, CORS, and Cache-Control.
              </p>
            </div>
            <div class="px-6 py-4 bg-[#fafafa]">
              <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-3">Steps covered</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-1.5 gap-x-8">
                {[
                  ['0', 'Crawler policy: GET /robots.txt'],
                  ['1', 'Page inventory: GET /sitemap.xml'],
                  ['2', 'Link inventory: GET /llms.txt'],
                  ['3', 'Expanded content: GET /llms-full.txt'],
                  ['4', '§4.5 headers: HEAD /agents.txt + /agents.json'],
                ].map(([num, label]) => (
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-[10px] text-[#bbb] shrink-0 w-4">{num}</span>
                    <span class="text-xs text-[#555]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </a>

        <!-- MCP demo -->
        <a href="/demo/mcp" class="block group no-underline h-full">
          <div class="border border-[#e5e5e5] group-hover:border-[#111] transition-colors h-full flex flex-col">
            <div class="px-6 py-5 border-b border-[#e5e5e5] flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111]">Model Context Protocol (MCP)</p>
                  <p class="font-mono text-[11px] text-[#999] mt-1">MCP 2024-11-05 · JSON-RPC 2.0 · Streamable HTTP · SSE</p>
                </div>
                <span class="font-mono text-xs text-[#999] group-hover:text-[#111] transition-colors shrink-0 mt-0.5">
                  Run demo →
                </span>
              </div>
              <p class="text-sm text-[#555] mt-3 leading-relaxed">
                Initialises an MCP session with this server's public MCP endpoint, enumerates the available tools, and invokes the <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">get_spec</code> tool to retrieve a live section of the agents.txt specification. Demonstrates the full Streamable HTTP handshake including session ID negotiation and SSE response parsing.
              </p>
            </div>
            <div class="px-6 py-4 bg-[#fafafa]">
              <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-3">Steps covered</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-1.5 gap-x-8">
                {[
                  ['0', 'Session initialisation (server assigns session ID)'],
                  ['1', 'Tool enumeration: tools/list'],
                  ['2', 'Tool invocation: get_spec (authorization section)'],
                  ['3', 'Tool invocation: validate_agents_txt (live /agents.txt)'],
                  ['4', 'Tool invocation: validate_agents_json (live /agents.json)'],
                  ['5', 'Tool invocation: audit_site (full compliance audit)'],
                ].map(([num, label]) => (
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-[10px] text-[#bbb] shrink-0 w-4">{num}</span>
                    <span class="text-xs text-[#555]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </a>

        <!-- Skills demo -->
        <a href="/demo/skills" class="block group no-underline h-full">
          <div class="border border-[#e5e5e5] group-hover:border-[#111] transition-colors h-full flex flex-col">
            <div class="px-6 py-5 border-b border-[#e5e5e5] flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111]">Skill Package Discovery</p>
                  <p class="font-mono text-[11px] text-[#999] mt-1">agents.txt v1.0 · Skills directive · agentskills.io · MCP get_skill</p>
                </div>
                <span class="font-mono text-xs text-[#999] group-hover:text-[#111] transition-colors shrink-0 mt-0.5">
                  Run demo →
                </span>
              </div>
              <p class="text-sm text-[#555] mt-3 leading-relaxed">
                Reads the skills index from <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.json</code>, fetches the declared skill package directly over HTTP, then retrieves the same content through the MCP <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">get_skill</code> tool. Demonstrates both retrieval paths available to an agent: plain HTTP and protocol-native MCP delivery.
              </p>
            </div>
            <div class="px-6 py-4 bg-[#fafafa]">
              <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-3">Steps covered</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-1.5 gap-x-8">
                {[
                  ['0', 'Skills index: agents.json · skills[]'],
                  ['1', 'HTTP retrieval: GET /skills/adopt-agents-txt/SKILL.md'],
                  ['2', 'MCP session initialisation (session ID for get_skill)'],
                  ['3', 'MCP tool invocation: get_skill("agents-txt-setup")'],
                ].map(([num, label]) => (
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-[10px] text-[#bbb] shrink-0 w-4">{num}</span>
                    <span class="text-xs text-[#555]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </a>

        <!-- Payments demo (x402) -->
        <a href="/demo/payments" class="block group no-underline h-full">
          <div class="border border-[#e5e5e5] group-hover:border-[#111] transition-colors h-full flex flex-col">
            <div class="px-6 py-5 border-b border-[#e5e5e5] flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111]">x402 Payment Protocol</p>
                  <p class="font-mono text-[11px] text-[#999] mt-1">x402 v2 · USDC · EVM (any chain) + Solana · Public facilitator</p>
                </div>
                <span class="font-mono text-xs text-[#999] group-hover:text-[#111] transition-colors shrink-0 mt-0.5">
                  Run demo →
                </span>
              </div>
              <p class="text-sm text-[#555] mt-3 leading-relaxed">
                Reads the declared x402 capability from <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.json</code>, then probes a synthetic gated route at <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">/x402</code> without credentials. The server responds with a real <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">402</code> carrying the recipient wallet in <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">accepts[].payTo</code> on Solana mainnet. Settlement is delegated to the public facilitator at x402.org.
              </p>
            </div>
            <div class="px-6 py-4 bg-[#fafafa]">
              <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-3">Steps covered</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-1.5 gap-x-8">
                {[
                  ['0', 'Announcement: GET /agents.json, payments.x402'],
                  ['1', 'Wire: GET /x402 → real 402 carrying payTo'],
                ].map(([num, label]) => (
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-[10px] text-[#bbb] shrink-0 w-4">{num}</span>
                    <span class="text-xs text-[#555]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </a>

        <!-- MPP demo -->
        <a href="/demo/mpp" class="block group no-underline h-full">
          <div class="border border-[#e5e5e5] group-hover:border-[#111] transition-colors h-full flex flex-col">
            <div class="px-6 py-5 border-b border-[#e5e5e5] flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111]">MPP (Machine Payments Protocol)</p>
                  <p class="font-mono text-[11px] text-[#999] mt-1">Reference only · Session-based · Tempo USDC.e · Stripe SPT</p>
                </div>
                <span class="font-mono text-xs text-[#999] group-hover:text-[#111] transition-colors shrink-0 mt-0.5">
                  Run demo →
                </span>
              </div>
              <p class="text-sm text-[#555] mt-3 leading-relaxed">
                Reads the declared MPP capability from <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.json</code>, then probes the synthetic gated route at <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">/mpp</code>. The server returns a real <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">402</code> with a <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">WWW-Authenticate: Payment</code> challenge composed by <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">mppx</code> from configured methods (Tempo and/or Stripe). The recipient is base64-encoded inside the challenge per spec §5.4.
              </p>
            </div>
            <div class="px-6 py-4 bg-[#fafafa]">
              <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-3">Steps covered</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-1.5 gap-x-8">
                {[
                  ['0', 'Declaration: agents.json · payments.mpp object'],
                  ['1', 'Wire (reference): 402 + WWW-Authenticate: Payment'],
                ].map(([num, label]) => (
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-[10px] text-[#bbb] shrink-0 w-4">{num}</span>
                    <span class="text-xs text-[#555]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </a>

        <!-- A2A demo -->
        <a href="/demo/a2a" class="block group no-underline h-full">
          <div class="border border-[#e5e5e5] group-hover:border-[#111] transition-colors h-full flex flex-col">
            <div class="px-6 py-5 border-b border-[#e5e5e5] flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111]">A2A AgentCard Discovery</p>
                  <p class="font-mono text-[11px] text-[#999] mt-1">agents.txt v1.0 · A2A directive (§9) · a2a-protocol.org · /.well-known/agent-card.json</p>
                </div>
                <span class="font-mono text-xs text-[#999] group-hover:text-[#111] transition-colors shrink-0 mt-0.5">
                  Run demo →
                </span>
              </div>
              <p class="text-sm text-[#555] mt-3 leading-relaxed">
                Reads the AgentCard index from <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.json</code>, fetches the AgentCard JSON document advertised by this site, parses its capabilities, declared protocol extensions (including the AP2 mandate extension), and skills, then confirms cross-file consistency between <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.txt</code> and <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.json</code> via the MCP <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">audit_site</code> tool. Demonstrates the discovery layer end to end; transport (JSON-RPC) is layered above and out of scope.
              </p>
            </div>
            <div class="px-6 py-4 bg-[#fafafa]">
              <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-3">Steps covered</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-1.5 gap-x-8">
                {[
                  ['0', 'A2A index: agents.json · a2a[]'],
                  ['1', 'AgentCard fetch: GET /.well-known/agent-card.json'],
                  ['2', 'Card parsing: capabilities · extensions · skills'],
                  ['3', 'Cross-file consistency: MCP audit_site'],
                ].map(([num, label]) => (
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-[10px] text-[#bbb] shrink-0 w-4">{num}</span>
                    <span class="text-xs text-[#555]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </a>

        <!-- UCP demo -->
        <a href="/demo/ucp" class="block group no-underline h-full">
          <div class="border border-[#e5e5e5] group-hover:border-[#111] transition-colors h-full flex flex-col">
            <div class="px-6 py-5 border-b border-[#e5e5e5] flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111]">UCP Profile Discovery + AP2</p>
                  <p class="font-mono text-[11px] text-[#999] mt-1">agents.txt v1.0 · UCP directive (§10) · ucp.dev · AP2 mandate layer · /.well-known/ucp</p>
                </div>
                <span class="font-mono text-xs text-[#999] group-hover:text-[#111] transition-colors shrink-0 mt-0.5">
                  Run demo →
                </span>
              </div>
              <p class="text-sm text-[#555] mt-3 leading-relaxed">
                Reads the profile index from <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.json</code>, fetches the UCP profile document advertised by this site, parses its declared services, capabilities, payment handlers (including the AP2 mandate extension), and signing keys, then confirms cross-file consistency between <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.txt</code> and <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">agents.json</code> via the MCP <code class="font-mono text-[11px] bg-[#f4f4f4] border border-[#e8e8e8] px-1 py-0.5">audit_site</code> tool. Also covers AP2 (Agent Payments Protocol): roles, mandate types, flows, and how mandates compose with the underlying rails (x402 / MPP). Discovery layer end to end; the commerce protocol (capability negotiation, signed requests) is layered above.
              </p>
            </div>
            <div class="px-6 py-4 bg-[#fafafa]">
              <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-3">Steps covered</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-1.5 gap-x-8">
                {[
                  ['0', 'UCP index: agents.json · ucp[]'],
                  ['1', 'Profile fetch: GET /.well-known/ucp'],
                  ['2', 'Profile parsing: services · capabilities · payment_handlers'],
                  ['3', 'Cross-file consistency: MCP audit_site'],
                  ['+', 'AP2 reference: roles · mandates · flows · cross-cut'],
                ].map(([num, label]) => (
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-[10px] text-[#bbb] shrink-0 w-4">{num}</span>
                    <span class="text-xs text-[#555]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </a>

        <!-- Auth demo -->
        <a href="/demo/auth" class="block group no-underline h-full">
          <div class="border border-[#e5e5e5] group-hover:border-[#111] transition-colors h-full flex flex-col">
            <div class="px-6 py-5 border-b border-[#e5e5e5] flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111]">Agent Auth Protocol</p>
