---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavRight from '../components/NavRight.astro';
import '../styles/global.css';
import { SPEC_VERSION } from '../config';
import { readFileSync } from 'node:fs';
// Import the actual /agents.txt and /agents.json this deployment serves and
// render them as the hero code preview. Build-time read means the preview can
// never drift from the served files: if either changes, the next deploy
// reflects it. agents.json is a structured `import` (native to Vite); agents.txt
// is a plain-text read since Astro/Vite does not have a built-in plain-text
// loader for files outside src/.
import agentsJsonData from '../../public/agents.json';
const agentsJsonPretty = JSON.stringify(agentsJsonData, null, 2);
const agentsTxt = readFileSync('public/agents.txt', 'utf-8').replace(/\n+$/, '');
---

<BaseLayout
  title="agents.txt Standard"
  description="The open specification for AI agent capability declarations. Layer 4 of the agent-readiness stack. The reference deployment at agents-txt.com serves the specification, the discovery files, the MCP endpoint, and live protocol demos."
  canonicalUrl="https://agents-txt.com"
>
  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-white border-b border-[#e5e5e5]">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="flex items-center no-underline shrink-0" aria-label="agents.txt"><img src="/assets/mark-2.svg" alt="agents.txt" width="26" height="26" class="h-[26px] w-[26px]" /></a>
        <span class="hidden sm:inline text-[#ccc] select-none">/</span>
      </div>
      <NavRight />
    </div>
  </header>

  <!-- Page body -->
  <div class="max-w-[1280px] mx-auto px-6 sm:px-10 pt-16 pb-24">

    <!-- Hero + Context (merged into a single 2-column grid so the agents.json
         preview on the right stretches to match the combined height of the
         hero copy and the "Where agents.txt fits" table on the left. The
         separator lives inside the left column, so it ends horizontally where
         the table ends rather than spanning the full page width. -->
    <section class="mb-14">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_minmax(0,443px)] gap-x-12 gap-y-10 items-stretch">

        <!-- Left column: hero copy → separator → context + table -->
        <div class="flex flex-col">

          <!-- Hero copy block -->
          <div class="pb-10 mb-10 border-b border-[#e5e5e5]">
            <h1 class="mb-6">
              <img
                src="/assets/wordmark-stacked.svg"
                alt="agents.txt — the declarative capability discovery layer"
                width="384"
                height="214"
                class="w-full max-w-[340px] h-auto"
              />
            </h1>
            <p class="text-sm text-[#555] leading-relaxed max-w-[64ch] mb-8">
              Two files at the site root: <span class="font-mono text-[#111]">/agents.txt</span> (plain text, one directive per line) and <span class="font-mono text-[#111]">/agents.json</span> (structured companion). Agents fetch them on first contact and learn what the site supports: payment protocols, authorization schemes, MCP servers, skill packages, and A2A AgentCards. No crawling, no protocol probing, no SDK to bundle. Implementation details live inside each protocol's own response surface; the discovery layer stays thin, static-cacheable, CC0-licensed, and protocol-agnostic by design.
            </p>
            <div class="flex flex-wrap items-center gap-3">
              <a
                href="/spec"
                class="inline-flex items-center gap-2 border border-[#111] bg-[#111] text-white text-xs font-semibold tracking-[0.06em] uppercase px-4 py-2.5 no-underline hover:bg-white hover:text-[#111] transition-colors"
              >
                Read the spec
              </a>
              <a
                href="/demo"
                class="inline-flex items-center gap-2 border border-[#111] text-[#111] text-xs font-semibold tracking-[0.06em] uppercase px-4 py-2.5 no-underline hover:bg-[#111] hover:text-white transition-colors"
              >
                Run the demos
              </a>
              <a
                href="https://github.com/agents-txt/agents-txt"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-xs font-semibold tracking-[0.06em] uppercase text-[#555] hover:text-[#111] transition-colors no-underline px-4 py-2.5"
              >
                GitHub →
              </a>
              <!-- Two equal-flex spacers centre the score pill in the
                   remaining row space on lg+: the first one sits between
                   GitHub and the pill, the second sits between the pill
                   and the right edge of the left column. They both have
                   flex-1, so the leftover horizontal room is split evenly,
                   placing the pill at the midpoint between the GitHub
                   button and the agents.json column. The spacers are
                   `hidden` below lg so the layout reverts to the natural
                   flex-wrap order on narrow viewports. -->
              <span class="hidden lg:block lg:flex-1" aria-hidden="true"></span>
              <!-- Live agent-readiness score from isitagentready.com. Compact
                   scoreboard-style pill: green "100" disc + two-line label.
                   Acts as a trust signal alongside the CTAs without taking
                   the focus off the primary "Read the spec" / "Run the demos"
                   buttons. -->
              <a
                href="https://isitagentready.com/agents-txt.com"
                target="_blank"
                rel="noopener noreferrer"
                title="Verified 100 / 100 on isitagentready.com"
                class="inline-flex items-center gap-2.5 border border-[#e5e5e5] hover:border-[#111] transition-colors no-underline pl-2 pr-3 py-1.5"
              >
                <span class="flex items-center justify-center w-7 h-7 rounded-full border-2 border-[#16a34a] text-[#16a34a] font-bold text-[11px] leading-none shrink-0">100</span>
                <span class="flex flex-col leading-tight">
                  <span class="text-[11px] font-semibold tracking-tight text-[#111]">Level 5 · Agent-Native</span>
                  <span class="font-mono text-[10px] text-[#777]">isitagentready.com →</span>
                </span>
              </a>
              <span class="hidden lg:block lg:flex-1" aria-hidden="true"></span>
            </div>
          </div>

          <!-- Context + table -->
          <div>
            <div class="mb-6">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#999] mb-2">Context</p>
              <h2 class="text-xl font-bold tracking-tight text-[#111] mb-2">Where agents.txt fits</h2>
              <p class="text-sm text-[#555] leading-relaxed">
                Four standards already cover the lower layers of how a website meets automated traffic. agents.txt is the fourth, sitting above content and adding the missing layer: agent-runtime capability declaration.
              </p>
            </div>

            <div class="border border-[#e5e5e5] overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-[#fafafa] border-b border-[#e5e5e5]">
                    <th class="text-left text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] px-5 py-3 w-16">Layer</th>
                    <th class="text-left text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] px-5 py-3">Concern</th>
                    <th class="text-left text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999] px-5 py-3">Standard</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-[#e5e5e5]">
                  <tr>
                    <td class="px-5 py-3 font-mono text-[#999] align-top">1</td>
                    <td class="px-5 py-3 text-[#555] align-top">Access control</td>
                    <td class="px-5 py-3 font-mono text-[#111] align-top">/robots.txt <span class="text-[#999] font-sans text-xs">(RFC 9309)</span></td>
                  </tr>
                  <tr>
                    <td class="px-5 py-3 font-mono text-[#999] align-top">2</td>
                    <td class="px-5 py-3 text-[#555] align-top">Page inventory</td>
                    <td class="px-5 py-3 font-mono text-[#111] align-top">/sitemap.xml <span class="text-[#999] font-sans text-xs">(sitemaps.org)</span></td>
                  </tr>
                  <tr>
                    <td class="px-5 py-3 font-mono text-[#999] align-top">3</td>
                    <td class="px-5 py-3 text-[#555] align-top">Content briefing</td>
                    <td class="px-5 py-3 font-mono text-[#111] align-top">/llms.txt <span class="text-[#999] font-sans text-xs">(llmstxt.org)</span></td>
                  </tr>
                  <tr class="bg-[#fafafa]">
                    <td class="px-5 py-3 font-mono text-[#111] font-semibold align-top">4</td>
                    <td class="px-5 py-3 text-[#111] font-semibold align-top">Agent capabilities</td>
                    <td class="px-5 py-3 font-mono text-[#111] align-top">/agents.txt + /agents.json <span class="text-[#999] font-sans text-xs">(this spec)</span></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Right column: live previews of /agents.txt and /agents.json,
             toggled by the tab bar at the top of the aside. Build-time read
             keeps both byte-identical to the files the deployment serves.
             - agents.txt (default): the aside is top-anchored inside its
               wrapper and sizes to its (small) content. The wrapper still
               reserves the full left-column height behind it, so the table
               below never shifts.
             - agents.json: the aside fills the wrapper (lg:inset-0 applied
               via the .json-active class), and the longer JSON scrolls
               inside it. Bottom edge then lines up with the bottom of the
               table's last row, as before.
             On mobile (single column) both prees fall back to a fixed
             max-h-[360px] and the absolute-positioning trick does not apply. -->
        <div class="lg:relative">
          <aside id="agents-preview" class="border border-[#e5e5e5] bg-[#fafafa] overflow-hidden flex flex-col lg:absolute lg:inset-x-0 lg:top-0">
            <!-- Tab bar -->
            <div class="flex items-stretch border-b border-[#e5e5e5] bg-white shrink-0">
              <button id="tab-txt" type="button" data-tab="txt" class="cursor-pointer font-mono text-[11px] font-semibold px-4 py-2.5 transition-colors border-b-2 border-[#111] text-[#111]">
                /agents.txt
              </button>
              <button id="tab-json" type="button" data-tab="json" class="cursor-pointer font-mono text-[11px] font-semibold px-4 py-2.5 transition-colors border-b-2 border-transparent text-[#777] hover:text-[#111]">
                /agents.json
              </button>
              <a
                id="agents-raw-link"
                href="/agents.txt"
                target="_blank"
                rel="noopener noreferrer"
                class="ml-auto self-center px-4 font-mono text-[10px] tracking-[0.06em] uppercase text-[#777] hover:text-[#111] transition-colors no-underline"
              >
                View raw →
              </a>
            </div>

            <!-- Two panes; the inactive one carries the `hidden` Tailwind class.
                 The toggle script swaps `hidden` between them on tab click. -->
            <pre id="pane-txt" class="scrollbar-thin px-4 py-3 font-mono text-[10px] leading-snug text-[#333] overflow-auto max-h-[360px] lg:max-h-[420px] m-0 bg-transparent">{agentsTxt}</pre>
            <pre id="pane-json" class="hidden scrollbar-thin px-4 py-3 font-mono text-[10px] leading-snug text-[#333] overflow-auto max-h-[360px] lg:max-h-none lg:flex-1 lg:min-h-0 m-0 bg-transparent">{agentsJsonPretty}</pre>
          </aside>
        </div>
      </div>
    </section>

    <!-- Adopt -->
    <section class="mb-14">
      <div class="mb-6">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#999] mb-2">Adopt</p>
        <h2 class="text-xl font-bold tracking-tight text-[#111] mb-2">Three ways to ship agents.txt on your own site</h2>
        <p class="text-sm text-[#555] leading-relaxed max-w-[68ch]">
          The format is plain UTF-8 text and the JSON companion is small. Most sites can hand-write both in five minutes; the other paths exist for projects that want regeneration on every build, dynamic discovery files, or framework-level payment middleware.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="border border-[#e5e5e5] px-5 py-4">
          <p class="font-mono text-[10px] text-[#999] uppercase tracking-[0.08em] mb-2">Path 1</p>
          <p class="text-sm font-semibold text-[#111] mb-2">Hand-write</p>
          <p class="text-xs text-[#777] leading-relaxed">Copy the directives that apply to your site, save the file as <span class="font-mono">/agents.txt</span>, mirror the structure in <span class="font-mono">/agents.json</span>. Read <a href="/spec" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#111] transition-all text-[#555]">the spec</a> for the directive reference or try the <a href="/demo" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#111] transition-all text-[#555]">demo</a></p>
        </div>
        <div class="border border-[#e5e5e5] px-5 py-4">
          <p class="font-mono text-[10px] text-[#999] uppercase tracking-[0.08em] mb-2">Path 2</p>
          <p class="text-sm font-semibold text-[#111] mb-2">Use a generator</p>
          <p class="text-xs text-[#777] leading-relaxed"><a href="https://github.com/agents-txt/herald" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#111] transition-all text-[#555]">HERALD</a> is the sibling project built to generate the discovery files for this site. Useful if you want all layers kept in sync on every build.
        </div>
        <div class="border border-[#e5e5e5] px-5 py-4">
          <p class="font-mono text-[10px] text-[#999] uppercase tracking-[0.08em] mb-2">Path 3</p>
          <p class="text-sm font-semibold text-[#111] mb-2">Read this deployment</p>
          <p class="text-xs text-[#777] leading-relaxed">The source for every route on this site is on <a href="https://github.com/agents-txt/agents-txt" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#111] transition-all text-[#555]">GitHub</a>. The reference workers (site, MCP, agent-auth) are Apache 2.0; vendor in or fork freely.</p>
        </div>
      </div>
    </section>

    <!-- Compose: your site, your discovery shape. Carries the message that
         the standard composes: once a site has /agents.txt and /agents.json,
         any further discovery file it publishes becomes addressable through
         them. -->
    <section class="mb-14">
      <div class="border border-[#e5e5e5]">
        <div class="px-5 py-3 border-b border-[#e5e5e5] bg-[#fafafa]">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#999]">Compose</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_minmax(0,440px)] gap-x-10 gap-y-8 items-center px-6 py-7">
          <div class="max-w-[44ch]">
            <p class="text-lg sm:text-xl font-bold tracking-tight text-[#111] leading-snug mb-3">
              Your site, your discovery shape.
            </p>
            <p class="text-sm text-[#555] leading-relaxed">
              Once <span class="font-mono text-[#111]">/agents.txt</span> and <span class="font-mono text-[#111]">/agents.json</span> are live, publish any extra discovery file your site needs (a <span class="font-mono text-[#111]">/changelog.json</span>, an <span class="font-mono text-[#111]">/openapi.json</span>, a <span class="font-mono text-[#111]">/.well-known/*</span> for an emerging standard) and reference it from <span class="font-mono text-[#111]">agents.json</span>. Parsers ignore fields they do not recognise by design. The standard composes. The shape of your site stays yours.
            </p>
          </div>
          <!-- Interactive seam: the agents.json on the left declares a
               `changelog` URL; the /changelog.json tab shows what that URL
               resolves to. The pattern works for any custom discovery file a
               site publishes. Reuses the same tab-toggle motif as the hero's
               /agents.txt ↔ /agents.json preview. -->
          <div id="compose-preview" class="border border-[#e5e5e5] bg-[#fafafa] overflow-hidden flex flex-col">
            <div class="flex items-stretch border-b border-[#e5e5e5] bg-white shrink-0">
              <button id="compose-tab-agents" type="button" class="cursor-pointer font-mono text-[11px] font-semibold px-4 py-2.5 transition-colors border-b-2 border-[#111] text-[#111]">
                /agents.json
              </button>
              <button id="compose-tab-api" type="button" class="cursor-pointer font-mono text-[11px] font-semibold px-4 py-2.5 transition-colors border-b-2 border-transparent text-[#777] hover:text-[#111]">
                /changelog.json
              </button>
              <span class="ml-auto self-center px-4 font-mono text-[10px] tracking-[0.06em] uppercase text-[#999]">on your site</span>
            </div>
            <pre id="compose-pane-agents" class="font-mono text-[11px] leading-relaxed text-[#333] px-4 py-3 overflow-auto m-0 bg-transparent">{`{
  "version":   "1.0",
  "mcp":       [...],
  "skills":    [...],
  "changelog": "https://yoursite.com/changelog.json",
  "docs":      "https://docs.yoursite.com"
}`}</pre>
            <pre id="compose-pane-api" class="hidden font-mono text-[11px] leading-relaxed text-[#333] px-4 py-3 overflow-auto m-0 bg-transparent">{`{
  "version": "1.0",
  "releases": [
    { "version": "2.4.0", "date": "2026-05-12" },
    { "version": "2.3.0", "date": "2026-04-28" }
  ]
}`}</pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Capability blocks at a glance -->
    <section class="mb-14">
      <div class="mb-6">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#999] mb-2">Spec at a glance</p>
        <h2 class="text-xl font-bold tracking-tight text-[#111] mb-2">An open set of capability blocks</h2>
        <p class="text-sm text-[#555] leading-relaxed max-w-[68ch]">
          Each block is independent and optional. A site emits only the blocks that apply to it; old parsers ignore any block they do not recognise. The blocks below are the ones currently registered in the spec. A protocol awaiting registration may be advertised with the <span class="font-mono">x-</span> prefix; new block types are added to the spec by amendment; older parsers ignore what they do not recognise.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          ['Payments',      '§8',  'Protocols:',        'x402, mpp, ap2',                                  'Per-request crypto micropayments, session-based fiat / stablecoin payments, and the AP2 mandate trust layer. Block opens with Protocols:; site-level policy hint Payments: required is optional.'],
          ['Authorization', '§11',  'Authorization:',    'agent-auth, oauth2',                              'Agent identity and access tokens. agent-auth gives each agent its own key and tracks per-request identity; oauth2 follows the standard OAuth client-credentials flow for machine clients. Identity: required is the optional site-level policy hint.'],
          ['MCP',           '§6',  'MCP:',              'Streamable HTTP',                                 'Model Context Protocol server endpoint discovery. The directive is repeatable; one line per MCP server.'],
          ['Skills',        '§7',  'Skills:',           'agentskills.io',                                  'Service-consumption skill packages. Each Skills: line points to a SKILL.md at the root of an agentskills.io-canonical folder.'],
          ['A2A',           '§9',  'A2A:',              'a2a-protocol.org',                                'A2A AgentCard URLs. Complements the canonical well-known path for multi-agent sites and non-canonical AgentCard locations.'],
          ['UCP',           '§10', 'UCP:',              'ucp.dev',                                         'Universal Commerce Protocol profile URLs. Profile document declares services, transport bindings, payment handlers, and signing keys. Complements the canonical /.well-known/ucp path for multi-profile sites.'],
        ].map(([name, section, directive, value, description]) => (
          <div class="border border-[#e5e5e5] px-5 py-4">
            <div class="flex items-baseline justify-between gap-3 mb-2">
              <p class="text-sm font-semibold text-[#111]">{name}</p>
              <p class="font-mono text-[10px] text-[#999]">spec {section}</p>
            </div>
            <p class="font-mono text-[11px] text-[#555] mb-2">
              <span class="text-[#111] font-semibold">{directive}</span> {value}
            </p>
            <p class="text-xs text-[#777] leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- What this site serves -->
    <section class="mb-14">
      <div class="mb-6">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#999] mb-2">Reference deployment</p>
        <h2 class="text-xl font-bold tracking-tight text-[#111] mb-2">
          What this site serves right now
        </h2>
        <p class="text-sm text-[#555] leading-relaxed max-w-[68ch]">
          Every route on the left column is live against this deployment. The discovery files, the well-known endpoints, the MCP server, and the live demos all execute against real production endpoints. The same set of routes are described in spec §4.5 as the worked self-proof for the static vs dynamic serving mechanism.
        </p>
      </div>

      <div class="border border-[#e5e5e5]">
        <div class="grid grid-cols-[1fr_auto] gap-x-6 px-5 py-3 border-b border-[#e5e5e5] bg-[#fafafa] text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">
          <span>Route</span>
          <span class="text-right">Open</span>
        </div>
        {[
          {
            label: 'agents.txt spec surfaces',
            note:  'spec §3 · §5',
            open:  true,
            rows: [
              ['/agents.txt',                       'Plain-text capability declaration (spec §3). Site identity plus the active capability blocks.',                                                                                       '/agents.txt',                       'text/plain'],
              ['/agents.json',                      'Structured companion to agents.txt (spec §5). Same information in JSON with richer per-block detail.',                                                                              '/agents.json',                      'application/json'],
            ],
          },
          {
            label: 'Capability discovery',
            note:  'spec §6 · §7 · §9 · §10 · §11',
            open:  false,
            rows: [
              ['/mcp',                              'Model Context Protocol endpoint (spec §6). Exposes get_spec, parse_agents_txt, validate_agents_txt, validate_agents_json, audit_site, get_skill. Streamable HTTP transport.',         '/mcp',                              'application/json · streamable-http'],
              ['/skills/adopt-agents-txt/SKILL.md', 'Service-consumption skill package (spec §7) that walks a developer through adopting agents.txt on their own site.',                                                                  '/skills/adopt-agents-txt/SKILL.md', 'text/plain'],
              ['/.well-known/agent-card.json',      'A2A AgentCard for this deployment (spec §9). Describes a reference meta-agent, declared skills, and the x402 payments extension.',                                                  '/.well-known/agent-card.json',      'application/json'],
              ['/.well-known/ucp',                  'UCP profile (spec §10). Declares services, transport bindings, payment handlers including the AP2 mandate extension, and signing keys.',                                            '/.well-known/ucp',                  'application/json'],
              ['/.well-known/agent-configuration',  'Agent Auth Protocol discovery (spec §11). Served by a dynamic handler; the only well-known route on this deployment whose headers are set in code.',                                  '/.well-known/agent-configuration',  'application/json'],
            ],
          },
          {
            label: 'Ecosystem discovery surfaces',
            note:  'RFC 8288 · RFC 9727 · SEP-2127 · agentskills.io v0.2.0 · Payment Discovery',
            open:  false,
            rows: [
              ['/.well-known/api-catalog',           'RFC 9727 linkset of the machine-readable APIs this deployment exposes. Each anchor carries service-desc and describedby relations pointing at its descriptor.',                     '/.well-known/api-catalog',           'application/linkset+json'],
              ['/.well-known/mcp/server-card.json',  'SEP-2127 server card for the MCP endpoint. Declares serverInfo, transport, and capability flags so agents can pre-screen the server before opening a session.',                       '/.well-known/mcp/server-card.json',  'application/json'],
              ['/.well-known/agent-skills/index.json','agentskills.io Discovery v0.2.0 index. Per-skill name, type, URL, and sha256 digest for artifact verification.',                                                                       '/.well-known/agent-skills/index.json','application/json'],
              ['/openapi.json',                      'OpenAPI 3.1 with x-payment-info per the Payment Discovery draft. Declares the /x402 and /mpp routes with their payable-operation metadata.',                                          '/openapi.json',                      'application/json'],
            ],
          },
          {
            label: 'Adjacent standards',
            note:  'RFC 9309 · sitemaps.org · llmstxt.org · RFC 9116',
            open:  false,
            rows: [
              ['/robots.txt',                       'RFC 9309 crawler access policy. Includes the spec §4.3 Allow rule that exposes /agents.txt at its canonical path.',                                                                  '/robots.txt',                       'text/plain'],
              ['/sitemap.xml',                      'sitemaps.org 0.9 page inventory. Layer 2 of the stack.',                                                                                                                              '/sitemap.xml',                      'application/xml'],
              ['/llms.txt',                         'Curated link inventory for LLM-friendly site browsing. Layer 3 of the stack (llmstxt.org).',                                                                                          '/llms.txt',                         'text/plain'],
              ['/llms-full.txt',                    'Expanded form of llms.txt with full markdown content inlined under each page heading. Also served on /, /spec, and /demo/* when the Accept header carries text/markdown.',           '/llms-full.txt',                    'text/plain · text/markdown'],
              ['/.well-known/security.txt',         'RFC 9116 vulnerability disclosure channel. Carries Contact, Expires, Canonical, and Policy.',                                                                                        '/.well-known/security.txt',         'text/plain'],
            ],
          },
          {
            label: 'Synthetic demo routes',
            note:  'spec §8.1 · §8.2',
            open:  false,
            rows: [
              ['/x402',                             'Synthetic gated route demonstrating the x402 v2 wire shape on Solana mainnet. Returns 402 with accepts[] on first contact; settles via the public x402.org facilitator after the agent supplies a signed payment payload.', '/x402', 'application/json · 402'],
              ['/mpp',                              'Synthetic gated route demonstrating the MPP wire shape. Returns 402 with a WWW-Authenticate: Payment challenge composed by mppx. Tempo and Stripe methods activate per the credentials configured on the worker.',       '/mpp',  'application/json · 402'],
            ],
          },
        ].map((group) => (
          <details open={group.open} class="route-group border-t border-[#e5e5e5] first:border-t-0">
            <summary class="grid grid-cols-[1fr_auto] gap-x-6 px-5 py-3 cursor-pointer list-none hover:bg-[#f5f5f5] transition-colors">
              <span class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#555] flex items-center">
                <span class="chevron inline-block w-3 mr-2 text-[#999] text-[10px]">▸</span>
                {group.label}
                <span class="ml-2 text-[#999] font-normal normal-case tracking-normal text-[10px]">· {group.rows.length} route{group.rows.length === 1 ? '' : 's'}</span>
              </span>
              <span class="text-right text-[10px] uppercase tracking-[0.08em] text-[#999] self-center font-mono">{group.note}</span>
            </summary>
            <ul class="divide-y divide-[#e5e5e5] m-0 p-0 list-none border-t border-[#e5e5e5] bg-white">
              {group.rows.map(([path, description, href, contentType]) => (
                <li class="grid grid-cols-[1fr_auto] gap-x-6 px-5 py-4 items-start hover:bg-[#fcfcfc] transition-colors">
                  <div class="min-w-0">
                    <p class="font-mono text-sm text-[#111] mb-1 break-all">{path}</p>
                    <p class="text-xs text-[#777] leading-relaxed mb-1">{description}</p>
                    <p class="font-mono text-[10px] text-[#999] tracking-[0.04em]">{contentType}</p>
                  </div>
                  <a href={href} class="font-mono text-xs text-[#555] hover:text-[#111] transition-colors no-underline shrink-0 mt-0.5">
                    Open →
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))}
      </div>

      <p class="text-xs text-[#999] mt-4 leading-relaxed max-w-[68ch]">
        The mechanism by which each route emits its response headers is documented in <a href="/spec#45-serving-requirements" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#111] transition-all text-[#555]">spec §4.5</a>. Static files share a single <span class="font-mono">_headers</span> configuration; dynamic handlers set their headers in code. The MCP server lives at <a href="https://mcp.agents-txt.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#111] transition-all text-[#555]">mcp.agents-txt.com</a> and is proxied through this origin so cross-origin clients see a single host.
      </p>
    </section>

    <!-- Status -->
    <section>
      <div class="border border-[#e5e5e5] px-6 py-5 bg-[#fafafa] grid grid-cols-1 sm:grid-cols-[auto_1fr] gap-x-8 gap-y-2">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">Status</p>
        <p class="text-sm text-[#111]">v{SPEC_VERSION}. Format and schema are stable. Patches accepted via PR; structural changes ship as RFCs against the spec.</p>
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">Spec license</p>
        <p class="text-sm text-[#111]">CC0 (public domain). Anyone may implement the standard without restriction.</p>
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">Reference code</p>
        <p class="text-sm text-[#111]">Apache 2.0. The workers in this repository are reference implementations only; production deployments may diverge.</p>
      </div>
    </section>

  </div>

  <!-- Footer -->
  <footer class="border-t border-[#e5e5e5] mt-4">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="text-xs text-[#999]">
        <img src="/assets/wordmark.svg" alt="agents.txt" class="inline-block h-[16px] w-auto align-middle" />
        {' '}
        <a href="/spec" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Spec</a>
        {' '}·{' '}
        <a href="/registry" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Registry</a>
        {' '}·{' '}
        <a href="/demo" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Demos</a>
      </div>
      <p class="text-xs text-[#bbb]">CC0 (spec) · Apache 2.0 (code).</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Native <details> styling for the route groups: hide the default disclosure
     marker and use a custom chevron that rotates when the group is open. */
  details.route-group > summary { list-style: none; }
  details.route-group > summary::-webkit-details-marker { display: none; }
  details.route-group > summary .chevron {
    transition: transform 200ms ease-out;
  }
  details.route-group[open] > summary .chevron {
    transform: rotate(90deg);
  }

  /* Match the spec page's nav-column scrollbar: thin, neutral grey thumb,
     transparent track. Kept here rather than in global.css because the only
     two scrolling elements on the site that want this style are the spec
     page nav (already has it inline) and these two preview panes. */
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: #e5e5e5 transparent;
  }
</style>

<script>
  // Tab toggle for the hero's /agents.txt + /agents.json preview.
  // Pure-DOM class swapping so there is no CSS-specificity dance with
  // Tailwind's atomic utilities. Each click hides one pane (`.hidden`),
  // shows the other, repaints the active-tab underline, and updates the
  // "View raw" link's href to point at whichever file is currently active.
  //
  // The aside itself is top-anchored on lg+ so it sizes to its content.
  // When /agents.json is active and the pane carries `lg:flex-1
  // lg:min-h-0`, the absolutely-positioned aside also picks up
  // `bottom: 0` so it fills the wrapper; we toggle that with a single
  // utility class on the aside.
  const aside   = document.getElementById('agents-preview');
  const rawLink = document.getElementById('agents-raw-link') as HTMLAnchorElement | null;
  const tabTxt  = document.getElementById('tab-txt');
  const tabJson = document.getElementById('tab-json');
  const paneTxt  = document.getElementById('pane-txt');
  const paneJson = document.getElementById('pane-json');

  function activate(mode: 'txt' | 'json') {
    if (!aside || !rawLink || !tabTxt || !tabJson || !paneTxt || !paneJson) return;
    const isJson = mode === 'json';

    paneTxt.classList.toggle('hidden',  isJson);
    paneJson.classList.toggle('hidden', !isJson);

    // Active-tab pill: dark text + dark bottom border on the active one.
    tabTxt.classList.toggle('text-[#111]',          !isJson);
    tabTxt.classList.toggle('border-[#111]',        !isJson);
    tabTxt.classList.toggle('text-[#777]',           isJson);
    tabTxt.classList.toggle('border-transparent',    isJson);
    tabJson.classList.toggle('text-[#111]',          isJson);
    tabJson.classList.toggle('border-[#111]',        isJson);
    tabJson.classList.toggle('text-[#777]',         !isJson);
    tabJson.classList.toggle('border-transparent', !isJson);

    // Collapse vs expand on lg+: in json mode the aside also picks up
    // `bottom: 0` so it fills the wrapper. Tailwind atomic utility
    // `lg:bottom-0` is toggled directly.
    aside.classList.toggle('lg:bottom-0', isJson);

    rawLink.href = isJson ? '/agents.json' : '/agents.txt';
  }

  tabTxt?.addEventListener('click',  () => activate('txt'));
  tabJson?.addEventListener('click', () => activate('json'));

  // ── Compose section tab toggle (/agents.json ↔ /api.json) ──────────────
  // Same mechanism as the hero toggle above: swap `hidden` between the two
  // panes, repaint the active-tab underline.
  const composeTabAgents = document.getElementById('compose-tab-agents');
  const composeTabApi    = document.getElementById('compose-tab-api');
  const composePaneAgents = document.getElementById('compose-pane-agents');
  const composePaneApi    = document.getElementById('compose-pane-api');

  function composeActivate(mode: 'agents' | 'api') {
    if (!composeTabAgents || !composeTabApi || !composePaneAgents || !composePaneApi) return;
    const isApi = mode === 'api';
    composePaneAgents.classList.toggle('hidden',  isApi);
    composePaneApi.classList.toggle('hidden',    !isApi);
    composeTabAgents.classList.toggle('text-[#111]',         !isApi);
    composeTabAgents.classList.toggle('border-[#111]',       !isApi);
    composeTabAgents.classList.toggle('text-[#777]',          isApi);
    composeTabAgents.classList.toggle('border-transparent',   isApi);
    composeTabApi.classList.toggle('text-[#111]',             isApi);
    composeTabApi.classList.toggle('border-[#111]',           isApi);
    composeTabApi.classList.toggle('text-[#777]',            !isApi);
    composeTabApi.classList.toggle('border-transparent',     !isApi);
  }
  composeTabAgents?.addEventListener('click', () => composeActivate('agents'));
  composeTabApi?.addEventListener('click',    () => composeActivate('api'));
</script>
